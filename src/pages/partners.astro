---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { client, partnersQuery } from '../lib/sanity';

const partners = await client.fetch(partnersQuery);
const founding = partners.filter((p: any) => p.order <= 2);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// All non-founding partners + ICAI in one carousel
const ECOSYSTEM = [
  { name: 'Thales Digital Factory', logo: `${base}/images/partners/tdf.png`,        url: 'https://www.thalesdigital.io/en/' },
  { name: 'SGInnovate',             logo: `${base}/images/partners/sginnovate.png`,  url: 'https://www.sginnovate.com/' },
  { name: 'Starburst Aerospace',    logo: `${base}/images/partners/starburst.png`,   url: 'https://starburst.aero/' },
  { name: 'e27 Media',              logo: null,                                       url: 'https://e27.co/' },
  { name: 'Meteomatics',            logo: `${base}/images/partners/meteomatics.png`, url: 'https://www.meteomatics.com/en/' },
  { name: 'Skysquitter',            logo: null,                                       url: 'https://www.skysquitter.com/en/home-2/' },
  { name: 'Aeroficial Intelligence',logo: null,                                       url: 'https://www.aeroficial.com/' },
  { name: 'Tomorrow.io',            logo: `${base}/images/partners/tomorrow.png`,    url: 'https://www.tomorrow.io/' },
  { name: 'ICAI',                   logo: `${base}/images/partners/icai.png`,        url: 'https://www.icai.aero' },
];
---

<Base title="Partners" description="AIR Lab's ecosystem of founding, local, and solutions partners advancing aviation technology in the Asia-Pacific region.">
  <Nav slot="nav" />

  <div class="page-hero">
    <div class="page-hero-content">
      <div class="section-label">Ecosystem</div>
      <h1>Our<br><strong>partners</strong></h1>
      <p>A growing ecosystem of industry leaders, research institutions, and innovative companies co-creating the future of air traffic management.</p>
    </div>
  </div>

  <section style="background: var(--off-white);">

    <!-- Founding Partners -->
    <div class="section-header">
      <div class="section-label">Founding Partners</div>
      <h2 class="section-title">Built on a strong<br><strong>foundation</strong></h2>
      <p class="section-intro" style="margin-top: 16px;">AIR Lab was founded through a unique public-private partnership between CAAS and Thales, bringing together regulatory expertise and world-class aviation technology.</p>
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 64px;">
      <a href="https://www.caas.gov.sg/" target="_blank" rel="noopener" style="background: #fff; border: 1px solid var(--border); border-radius: 12px; padding: 32px; display: flex; flex-direction: column; gap: 12px; text-decoration: none; transition: box-shadow 0.2s;">
        <img src={`${base}/images/partners/caas.png`} alt="CAAS" style="max-height: 40px; max-width: 140px; object-fit: contain;" />
        <div style="font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em;">Institutional</div>
        <div style="font-size: 13px; color: var(--teal);">Visit website →</div>
      </a>
      <a href="https://www.thalesgroup.com/en" target="_blank" rel="noopener" style="background: #fff; border: 1px solid var(--border); border-radius: 12px; padding: 32px; display: flex; flex-direction: column; gap: 12px; text-decoration: none; transition: box-shadow 0.2s;">
        <img src={`${base}/images/partners/thales.webp`} alt="Thales" style="max-height: 40px; max-width: 140px; object-fit: contain;" />
        <div style="font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em;">Industry</div>
        <div style="font-size: 13px; color: var(--teal);">Visit website →</div>
      </a>
    </div>

    <!-- Sub-section: Singapore's innovation ecosystem (grid) -->
    <div class="ecosystem-sub">
      <div class="ecosystem-sub-label">Singapore's innovation ecosystem</div>
      <div class="eco-grid">
        {ECOSYSTEM.map(p => (
          <a href={p.url} target="_blank" rel="noopener" class="eco-cell">
            {p.logo
              ? <img src={p.logo} alt={p.name} />
              : <span class="eco-name">{p.name}</span>
            }
          </a>
        ))}
      </div>
    </div>

  </section>

  <!-- ── Partnerships with Startups ────────────────────────────────────── -->
  <section class="startup-section">

    <div class="startup-header">
      <div class="section-label" style="color: var(--teal);">Startup Programme</div>
      <h2 class="section-title" style="color: #fff;">Partnerships<br><strong>with startups</strong></h2>
      <p style="color: rgba(255,255,255,0.6); font-size: 17px; font-weight: 300; line-height: 1.65; max-width: 560px;">AIR Lab connects innovative startups with the ATM ecosystem — providing access to operational data, technical infrastructure, and a global network of aviation stakeholders.</p>
    </div>

    <!-- 1. Mission -->
    <div class="startup-block">
      <div class="startup-block-label">01 — Our mission</div>
      <div class="mission-grid">
        <div class="mission-card">
          <div class="mission-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3>Build stronger bridges between startups and ATM stakeholders</h3>
          <p>Identify real-world challenges and explore scalable solutions together.</p>
        </div>
        <div class="mission-card">
          <div class="mission-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
          </div>
          <h3>Foster innovation in the APAC ATM ecosystem</h3>
          <p>Support the transition to smarter, more collaborative air traffic systems across the region.</p>
        </div>
      </div>
    </div>

    <!-- 2. Process -->
    <div class="startup-block">
      <div class="startup-block-label">02 — The process</div>
      <div class="process-steps">
        {[
          { n: '1', title: 'Scouting', desc: 'AIR Lab identifies high-potential startups with solutions relevant to ATM challenges.' },
          { n: '2', title: 'Use Case Creation', desc: 'Use case curation and presentation of proposal to a panel from AIR Lab & CAAS.' },
          { n: '3', title: 'POC', desc: 'First 3 months to demonstrate that the solution can integrate to AIR Lab\'s platform through open APIs.' },
          { n: '4', title: 'Extended POC', desc: 'Further prove solution accuracy and resolution — requiring additional computing power and real data.' },
          { n: '5', title: 'AIRspace Hub', desc: 'Showcasing the validated solution to other ATM stakeholders to facilitate further growth.' },
        ].map((step, i) => (
          <div class="process-step" data-step={i}>
            <div class="ps-num">{step.n}</div>
            <div class="ps-content">
              <div class="ps-title">{step.title}</div>
              <div class="ps-desc">{step.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- 3. Examples -->
    <div class="startup-block">
      <div class="startup-block-label">03 — Examples</div>
      <div class="startup-examples">

        <!-- Meteomatics -->
        <div class="startup-card">
          <div class="sc-logo">
            <img src={`${base}/images/partners/meteomatics.png`} alt="Meteomatics" />
          </div>
          <div class="sc-body">
            <h3 class="sc-title">Meteomatics</h3>
            <p class="sc-desc">Meteomatics joined AIR Lab to integrate their high-resolution weather forecasting data — the SING1K model — directly into the Regional Collaboration Platform. The partnership explores how precise precipitation and wind data can improve route planning, reduce fuel consumption, and enhance situational awareness for APAC ANSPs.</p>
            <a href={`${base}/news/meteomatics-airlab-weather-forecasting-atm`} class="sc-link">Read the article →</a>
          </div>
        </div>

        <!-- Hela Labs -->
        <div class="startup-card">
          <div class="sc-img-wrap">
            <img src={`${base}/images/startups/hela-labs-1.jpg`} alt="Hela Labs demo day" class="sc-photo" />
            <img src={`${base}/images/startups/hela-labs-2.jpg`} alt="Hela Labs demo day" class="sc-photo sc-photo--2" />
          </div>
          <div class="sc-body">
            <h3 class="sc-title">Hela Labs</h3>
            <p class="sc-desc">Hela Labs participated in AIR Lab's startup programme, presenting their solution at a demo day with AIR Lab and CAAS. The collaboration explores how their technology can support ATM operations across the APAC region, from data processing to real-time decision support.</p>
          </div>
        </div>

      </div>
    </div>

  </section>

  <section style="background: var(--navy); padding: 100px 80px;">
    <div style="max-width: 600px; margin: 0 auto; text-align: center;">
      <div class="section-label">Become a partner</div>
      <h2 class="section-title" style="color: #fff; margin-bottom: 20px;">Interested in<br><strong>collaborating?</strong></h2>
      <p style="font-size: 17px; color: rgba(255,255,255,0.6); margin-bottom: 40px; font-weight: 300; line-height: 1.65;">We're always looking for partners who share our vision of open, collaborative aviation innovation.</p>
      <a href={`${base}/contact`} class="btn-airlab">Get in touch →</a>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  .ecosystem-sub {
    border-top: 1px solid var(--border);
    padding-top: 40px;
  }
  .ecosystem-sub-label {
    font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 24px; font-weight: 500;
  }
  .eco-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
  }
  .eco-cell {
    height: 120px;
    background: #fff; border: 1px solid var(--border); border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    padding: 20px 24px; text-decoration: none; transition: border-color 0.2s, box-shadow 0.2s;
  }
  .eco-cell:hover { border-color: var(--teal); box-shadow: 0 2px 12px rgba(6,113,129,0.1); }
  .eco-cell img { max-height: 64px; max-width: 140px; object-fit: contain; }
  .eco-name { font-size: 13px; font-weight: 600; color: var(--navy); text-align: center; line-height: 1.3; }

  /* ── Startup section ── */
  .startup-section { background: #0d1b2a; padding: 100px 80px; display: flex; flex-direction: column; gap: 80px; }
  .startup-header { max-width: 640px; }
  .startup-block-label { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--teal); margin-bottom: 32px; font-weight: 500; }
  .startup-block { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 48px; }

  /* Mission */
  .mission-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .mission-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 36px; transition: border-color 0.2s, background 0.2s; }
  .mission-card:hover { background: rgba(6,113,129,0.12); border-color: var(--teal); }
  .mission-icon { width: 44px; height: 44px; border: 1px solid rgba(6,113,129,0.5); border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px; }
  .mission-icon svg { width: 22px; height: 22px; stroke: var(--teal); }
  .mission-card h3 { font-size: 16px; font-weight: 600; color: #fff; margin-bottom: 10px; line-height: 1.4; }
  .mission-card p { font-size: 14px; color: rgba(255,255,255,0.55); line-height: 1.6; }

  /* Process */
  .process-steps { display: grid; grid-template-columns: repeat(5, 1fr); gap: 0; }
  .process-step { position: relative; padding: 24px 20px 24px 0; cursor: default; }
  .process-step::after { content: '→'; position: absolute; right: 0; top: 30px; color: rgba(255,255,255,0.2); font-size: 18px; }
  .process-step:last-child::after { display: none; }
  .ps-num { font-size: 36px; font-weight: 700; color: var(--teal); opacity: 0.5; line-height: 1; margin-bottom: 12px; transition: opacity 0.2s; }
  .process-step:hover .ps-num { opacity: 1; }
  .ps-title { font-size: 15px; font-weight: 600; color: #fff; margin-bottom: 8px; }
  .ps-desc { font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.55; transition: color 0.2s; }
  .process-step:hover .ps-desc { color: rgba(255,255,255,0.8); }

  /* Examples */
  .startup-examples { display: flex; flex-direction: column; gap: 40px; }
  .startup-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; padding: 40px; display: grid; grid-template-columns: 200px 1fr; gap: 40px; align-items: start; transition: border-color 0.2s; }
  .startup-card:hover { border-color: rgba(6,113,129,0.5); }
  .sc-logo { display: flex; align-items: center; justify-content: center; height: 80px; }
  .sc-logo img { max-height: 60px; max-width: 160px; object-fit: contain; filter: brightness(0) invert(1); opacity: 0.85; }
  .sc-img-wrap { position: relative; height: 160px; border-radius: 10px; overflow: hidden; }
  .sc-photo { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: opacity 0.4s; }
  .sc-photo--2 { opacity: 0; }
  .sc-img-wrap:hover .sc-photo--2 { opacity: 1; }
  .sc-img-wrap:hover .sc-photo:not(.sc-photo--2) { opacity: 0; }
  .sc-title { font-size: 20px; font-weight: 600; color: #fff; margin-bottom: 12px; }
  .sc-desc { font-size: 14px; color: rgba(255,255,255,0.6); line-height: 1.7; margin-bottom: 20px; }
  .sc-link { font-size: 13px; color: var(--teal); text-decoration: none; font-weight: 500; }
  .sc-link:hover { color: #fff; }
</style>

