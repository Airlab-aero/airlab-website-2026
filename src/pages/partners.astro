---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { client, partnersQuery } from '../lib/sanity';

const partners = await client.fetch(partnersQuery);
const founding = partners.filter((p: any) => p.order <= 2);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// All non-founding partners + ICAI in one carousel
const ECOSYSTEM = [
  { name: 'Thales Digital Factory', logo: `${base}/images/partners/tdf.png`,        url: 'https://www.thalesdigital.io/en/' },
  { name: 'SGInnovate',             logo: `${base}/images/partners/sginnovate.png`,  url: 'https://www.sginnovate.com/' },
  { name: 'Starburst Aerospace',    logo: `${base}/images/partners/starburst.png`,   url: 'https://starburst.aero/' },
  { name: 'e27 Media',              logo: null,                                       url: 'https://e27.co/' },
  { name: 'Meteomatics',            logo: `${base}/images/partners/meteomatics.png`, url: 'https://www.meteomatics.com/en/' },
  { name: 'Skysquitter',            logo: null,                                       url: 'https://www.skysquitter.com/en/home-2/' },
  { name: 'Aeroficial Intelligence',logo: null,                                       url: 'https://www.aeroficial.com/' },
  { name: 'Tomorrow.io',            logo: `${base}/images/partners/tomorrow.png`,    url: 'https://www.tomorrow.io/' },
  { name: 'ICAI',                   logo: `${base}/images/partners/icai.png`,        url: 'https://www.icai.aero' },
];
---

<Base title="Partners" description="AIR Lab's ecosystem of founding, local, and solutions partners advancing aviation technology in the Asia-Pacific region.">
  <Nav slot="nav" />

  <div class="page-hero">
    <div class="page-hero-content">
      <div class="section-label">Ecosystem</div>
      <h1>Our<br><strong>partners</strong></h1>
      <p>A growing ecosystem of industry leaders, research institutions, and innovative companies co-creating the future of air traffic management.</p>
    </div>
  </div>

  <section style="background: var(--off-white);">

    <!-- Founding Partners -->
    <div class="section-header">
      <div class="section-label">Founding Partners</div>
      <h2 class="section-title">Built on a strong<br><strong>foundation</strong></h2>
      <p class="section-intro" style="margin-top: 16px;">AIR Lab was founded through a unique public-private partnership between CAAS and Thales, bringing together regulatory expertise and world-class aviation technology.</p>
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 64px;">
      <a href="https://www.caas.gov.sg/" target="_blank" rel="noopener" style="background: #fff; border: 1px solid var(--border); border-radius: 12px; padding: 32px; display: flex; flex-direction: column; gap: 12px; text-decoration: none; transition: box-shadow 0.2s;">
        <img src={`${base}/images/partners/caas.png`} alt="CAAS" style="max-height: 70px; max-width: 200px; object-fit: contain;" />
        <div style="font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em;">Institutional</div>
        <div style="font-size: 13px; color: var(--teal);">Visit website →</div>
      </a>
      <a href="https://www.thalesgroup.com/en" target="_blank" rel="noopener" style="background: #fff; border: 1px solid var(--border); border-radius: 12px; padding: 32px; display: flex; flex-direction: column; gap: 12px; text-decoration: none; transition: box-shadow 0.2s;">
        <img src={`${base}/images/partners/thales.webp`} alt="Thales" style="max-height: 70px; max-width: 200px; object-fit: contain;" />
        <div style="font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em;">Industry</div>
        <div style="font-size: 13px; color: var(--teal);">Visit website →</div>
      </a>
    </div>

    <!-- Sub-section: Singapore's innovation ecosystem (grid) -->
    <div class="ecosystem-sub">
      <div class="ecosystem-sub-label">Singapore's innovation ecosystem</div>
      <div class="eco-grid">
        {ECOSYSTEM.map(p => (
          <a href={p.url} target="_blank" rel="noopener" class="eco-cell">
            {p.logo
              ? <img src={p.logo} alt={p.name} />
              : <span class="eco-name">{p.name}</span>
            }
          </a>
        ))}
      </div>
    </div>

    <!-- 04 ATM Ecosystem -->
    <div class="sp-block">
      <div class="sp-block-num">04</div>
      <div class="sp-block-content">
        <h3 class="sp-block-title">ATM Ecosystem</h3>

        <div class="eco-wheel-wrap">
          <!-- Centre -->
          <div class="eco-center">
            <svg viewBox="0 0 60 60" fill="none"><circle cx="30" cy="30" r="28" stroke="var(--teal)" stroke-width="1.5" stroke-dasharray="4 3"/><text x="30" y="26" text-anchor="middle" font-size="8" fill="#fff" font-weight="700" font-family="system-ui">AIR</text><text x="30" y="36" text-anchor="middle" font-size="8" fill="#fff" font-weight="700" font-family="system-ui">LAB</text></svg>
          </div>

          <!-- Orbit nodes -->
          {[
            { id: 'research',  label: 'Research\nTopics',    icon: 'M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18', angle: 0 },
            { id: 'academia',  label: 'Universities\n& Institutes', icon: 'M22 10v6M2 10l10-5 10 5-10 5zM6 12v5c3 3 9 3 12 0v-5', angle: 90 },
            { id: 'usecases',  label: 'Use\nCases',          icon: 'M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 0 2-2h2a2 2 0 0 0 2 2', angle: 180 },
            { id: 'industry',  label: 'Industry\nPartners',  icon: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M23 21v-2a4 4 0 0 0-3-3.87M9 7a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM16 3.13a4 4 0 0 1 0 7.75', angle: 270 },
          ].map(node => (
            <button class="eco-node" data-eco={node.id} style={`--angle: ${node.angle}deg`}>
              <div class="eco-node-inner">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d={node.icon}/></svg>
              </div>
              <div class="eco-node-label">{node.label.split('\n').map(l => <span>{l}</span>)}</div>
            </button>
          ))}

          <!-- Connector lines (SVG overlay) -->
          <svg class="eco-lines" viewBox="0 0 400 400" fill="none">
            <line x1="200" y1="200" x2="200" y2="60"  stroke="rgba(6,113,129,0.4)" stroke-width="1" stroke-dasharray="4 3"/>
            <line x1="200" y1="200" x2="340" y2="200" stroke="rgba(6,113,129,0.4)" stroke-width="1" stroke-dasharray="4 3"/>
            <line x1="200" y1="200" x2="200" y2="340" stroke="rgba(6,113,129,0.4)" stroke-width="1" stroke-dasharray="4 3"/>
            <line x1="200" y1="200" x2="60"  y2="200" stroke="rgba(6,113,129,0.4)" stroke-width="1" stroke-dasharray="4 3"/>
          </svg>
        </div>

        <!-- Detail panel -->
        <div class="eco-detail" id="ecoDetail">
          <div class="eco-detail-placeholder">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:24px;height:24px;stroke:var(--teal)"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
            <span>Cliquez sur un segment pour explorer</span>
          </div>
        </div>

      </div>
    </div>

  </section>

  <!-- ── Partnerships with Startups ────────────────────────────────────── -->
  <section class="startup-section">

    <!-- Header -->
    <div class="sp-header-row">
      <div>
        <div class="sp-eyebrow">AIRspace Hub · Startup Programme</div>
        <h2 class="sp-title">Partnerships<br><strong>with startups</strong></h2>
      </div>
      <div>
        <p class="sp-intro">Advancing global aviation efficiency and sustainability by creating innovative ATM solutions through open technologies and collaboration. AIR Lab connects startups with operational data, technical infrastructure, and a global network of aviation stakeholders.</p>
        <a href="https://airspace-hub.aero" target="_blank" rel="noopener" class="sp-hub-link">Explore AIRspace Hub →</a>
      </div>
    </div>

    <!-- 01 Mission -->
    <div class="sp-block">
      <div class="sp-block-num">01</div>
      <div class="sp-block-content">
        <h3 class="sp-block-title">Our mission</h3>
        <div class="mission-grid">
          <div class="mission-card">
            <div class="mission-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div class="mission-side">For innovators</div>
            <h4>Build stronger bridges between startups and ATM stakeholders</h4>
            <p>Mentorship from industry experts, enhanced visibility to decision-makers and investors, and direct networking with aviation leaders.</p>
          </div>
          <div class="mission-card">
            <div class="mission-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            </div>
            <div class="mission-side">For adopters</div>
            <h4>Access validated solutions for the APAC ATM ecosystem</h4>
            <p>Curated technologies in AI, meteorology, and emerging fields — proven through real operational data and rigorous testing.</p>
          </div>
        </div>
        <div class="mission-tags">
          <span class="mtag">Artificial Intelligence</span>
          <span class="mtag">Meteorology</span>
          <span class="mtag">Blockchain</span>
          <span class="mtag">Open Technologies</span>
          <span class="mtag">ATM Innovation</span>
        </div>
      </div>
    </div>

    <!-- 02 Process -->
    <div class="sp-block">
      <div class="sp-block-num">02</div>
      <div class="sp-block-content">
        <h3 class="sp-block-title">The process</h3>
        <div class="process-track">
          <div class="process-line"></div>
          {[
            { title: 'Scouting', desc: 'Identifying promising technologies across AI, blockchain, and meteorology that address real ATM challenges.' },
            { title: 'Use Case Development', desc: 'Use case curation & presentation of proposal to a panel from AIR Lab & CAAS.' },
            { title: 'Initial POC', desc: 'For 1st 3 months to demonstrate that the solution can integrate to AIR Lab\'s platform through open APIs.' },
            { title: 'Extended Validation', desc: 'To further prove solution\'s accuracy & resolution; which requires more computing power.' },
            { title: 'AIRspace Hub', desc: 'To facilitate further growth – showcasing their validated solution to other ATM stakeholders.' },
          ].map((step, i) => (
            <button class={`ps-step ${i === 0 ? 'active' : ''}`} data-idx={i}>
              <div class="ps-dot"></div>
              <div class="ps-step-num">{i + 1}</div>
              <div class="ps-step-title">{step.title}</div>
            </button>
          ))}
        </div>
        <div class="process-detail" id="processDetail">
          <div class="pd-num">1</div>
          <div>
            <div class="pd-title">Scouting</div>
            <div class="pd-desc">Identifying promising technologies across AI, blockchain, and meteorology that address real ATM challenges.</div>
          </div>
        </div>
      </div>
    </div>

    <!-- 03 Examples -->
    <div class="sp-block">
      <div class="sp-block-num">03</div>
      <div class="sp-block-content">
        <h3 class="sp-block-title">Examples</h3>
        <div class="examples-grid">

          <!-- Meteomatics -->
          <div class="ex-card">
            <div class="ex-card-top">
              <div class="ex-logo-wrap">
                <img src={`${base}/images/partners/meteomatics.png`} alt="Meteomatics" class="ex-logo" />
              </div>
              <span class="ex-tag">Meteorology · SING1K</span>
            </div>
            <h4 class="ex-name">Meteomatics</h4>
            <p class="ex-desc">Meteomatics built SING1K — a custom weather forecast model at 1×1 km resolution for Singapore — integrated directly into the RCP. The partnership improves route planning, reduces fuel consumption, and enhances situational awareness for APAC ANSPs.</p>
            <blockquote class="ex-quote">"This collaboration marks a significant advancement in weather forecasting for ATM in Singapore, using advanced tech to reduce weather risks and improve air traffic safety."<cite>— Arjen Piest, Meteomatics</cite></blockquote>
            <a href={`${base}/news/meteomatics-airlab-weather-forecasting-atm`} class="ex-link">Read the article →</a>
          </div>

          <!-- Hela Labs -->
          <div class="ex-card">
            <div class="ex-card-top ex-card-top--photos">
              <img src={`${base}/images/startups/hela-labs-1.jpg`} alt="Hela Labs" class="ex-photo ex-photo--1" />
              <img src={`${base}/images/startups/hela-labs-2.jpg`} alt="Hela Labs" class="ex-photo ex-photo--2" />
            </div>
            <span class="ex-tag">Demo Day</span>
            <h4 class="ex-name">Hela Labs</h4>
            <p class="ex-desc">Hela Labs presented their solution at a demo day with AIR Lab and CAAS, exploring how their technology can support ATM operations across the APAC region — from data processing to real-time decision support.</p>
          </div>

        </div>
      </div>
    </div>

  </section>

  <section style="background: var(--navy); padding: 100px 80px;">
    <div style="max-width: 600px; margin: 0 auto; text-align: center;">
      <div class="section-label">Become a partner</div>
      <h2 class="section-title" style="color: #fff; margin-bottom: 20px;">Interested in<br><strong>collaborating?</strong></h2>
      <p style="font-size: 17px; color: rgba(255,255,255,0.6); margin-bottom: 40px; font-weight: 300; line-height: 1.65;">We're always looking for partners who share our vision of open, collaborative aviation innovation.</p>
      <a href={`${base}/contact`} class="btn-airlab">Get in touch →</a>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  .ecosystem-sub {
    border-top: 1px solid var(--border);
    padding-top: 40px;
  }
  .ecosystem-sub-label {
    font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 24px; font-weight: 500;
  }
  .eco-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
  }
  .eco-cell {
    height: 120px;
    background: #fff; border: 1px solid var(--border); border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    padding: 20px 24px; text-decoration: none; transition: border-color 0.2s, box-shadow 0.2s;
  }
  .eco-cell:hover { border-color: var(--teal); box-shadow: 0 2px 12px rgba(6,113,129,0.1); }
  .eco-cell img { max-height: 64px; max-width: 140px; object-fit: contain; }
  .eco-name { font-size: 13px; font-weight: 600; color: var(--navy); text-align: center; line-height: 1.3; }

  /* ── ATM Ecosystem wheel ── */
  .eco-wheel-wrap { position: relative; width: 400px; height: 400px; margin: 0 auto 32px; flex-shrink: 0; }
  .eco-center { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 80px; height: 80px; background: rgba(6,113,129,0.2); border: 2px solid var(--teal); border-radius: 50%; display: flex; align-items: center; justify-content: center; z-index: 2; }
  .eco-center svg { width: 60px; height: 60px; }
  .eco-lines { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0; }
  .eco-node { position: absolute; background: none; border: none; cursor: pointer; display: flex; flex-direction: column; align-items: center; gap: 8px; z-index: 3; padding: 0; transform: translate(-50%, -50%); transition: all 0.2s; }
  .eco-node[data-eco="research"]  { top: 15%;  left: 50%; }
  .eco-node[data-eco="academia"]  { top: 50%;  left: 85%; }
  .eco-node[data-eco="usecases"]  { top: 85%;  left: 50%; }
  .eco-node[data-eco="industry"]  { top: 50%;  left: 15%; }
  .eco-node-inner { width: 52px; height: 52px; border-radius: 50%; background: rgba(6,113,129,0.15); border: 1.5px solid rgba(6,113,129,0.5); display: flex; align-items: center; justify-content: center; transition: all 0.25s; }
  .eco-node-inner svg { width: 22px; height: 22px; stroke: var(--teal); }
  .eco-node.active .eco-node-inner, .eco-node:hover .eco-node-inner { background: var(--teal); border-color: var(--teal); box-shadow: 0 0 20px rgba(6,113,129,0.5); }
  .eco-node.active .eco-node-inner svg, .eco-node:hover .eco-node-inner svg { stroke: #fff; }
  .eco-node-label { display: flex; flex-direction: column; align-items: center; }
  .eco-node-label span { font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.75); line-height: 1.4; text-align: center; }
  .eco-node.active .eco-node-label span { color: #fff; }
  .eco-detail { background: rgba(6,113,129,0.12); border: 1px solid rgba(6,113,129,0.35); border-radius: 14px; padding: 28px 32px; min-height: 120px; display: flex; align-items: flex-start; transition: all 0.3s; }
  .eco-detail-placeholder { display: flex; align-items: center; gap: 12px; color: rgba(255,255,255,0.4); font-size: 13px; margin: auto; }
  .eco-detail-title { font-size: 16px; font-weight: 700; color: #ffffff; margin-bottom: 14px; }
  .eco-detail-list { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 8px; }
  .eco-detail-list li { font-size: 13px; color: #ffffff; line-height: 1.65; padding-left: 16px; position: relative; }
  .eco-detail-list li::before { content: ''; position: absolute; left: 0; top: 7px; width: 5px; height: 5px; border-radius: 50%; background: var(--teal); }
  .eco-detail-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 4px; }
  .eco-detail-tag { font-size: 12px; font-weight: 600; color: #fff; background: rgba(6,113,129,0.3); border: 1px solid rgba(6,113,129,0.5); border-radius: 20px; padding: 5px 14px; }

  /* ── Startup section ── */
  .startup-section { background: #0b1622; padding: 100px 80px; display: flex; flex-direction: column; gap: 80px; }

  /* Header */
  .sp-header-row { display: grid; grid-template-columns: auto 1fr; gap: 40px; align-items: start; }
  .sp-eyebrow { font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--teal); font-weight: 600; margin-bottom: 16px; }
  .sp-title { font-size: clamp(32px, 4vw, 48px); font-weight: 300; color: #fff; line-height: 1.15; margin: 0; }
  .sp-title strong { font-weight: 700; }
  .sp-intro { font-size: 16px; color: rgba(255,255,255,0.82); line-height: 1.75; margin: 0 0 24px; }
  .sp-hub-link { font-size: 14px; font-weight: 700; color: #fff; text-decoration: none; background: var(--teal); padding: 10px 22px; border-radius: 24px; display: inline-block; transition: all 0.2s; letter-spacing: 0.01em; }
  .sp-hub-link:hover { background: #048a9a; color: #fff; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(6,113,129,0.35); }

  /* Blocks */
  .sp-block { display: grid; grid-template-columns: 80px 1fr; gap: 40px; border-top: 1px solid rgba(255,255,255,0.08); padding-top: 56px; }
  .sp-block-num { font-size: 13px; font-weight: 700; color: var(--teal); letter-spacing: 0.05em; padding-top: 6px; }
  .sp-block-title { font-size: 26px; font-weight: 600; color: #fff; margin: 0 0 32px; }

  /* Mission */
  .mission-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .mission-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 32px; transition: all 0.25s; cursor: default; }
  .mission-card:hover { background: rgba(6,113,129,0.1); border-color: rgba(6,113,129,0.4); transform: translateY(-2px); }
  .mission-icon { width: 40px; height: 40px; background: rgba(6,113,129,0.15); border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-bottom: 18px; }
  .mission-icon svg { width: 20px; height: 20px; stroke: var(--teal); }
  .mission-card h4 { font-size: 15px; font-weight: 600; color: #fff; margin: 0 0 10px; line-height: 1.45; }
  .mission-card p { font-size: 13px; color: rgba(255,255,255,0.75); line-height: 1.65; margin: 0; }
  .mission-side { font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--teal); font-weight: 600; margin-bottom: 10px; }
  .mission-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 24px; }
  .mtag { font-size: 12px; color: rgba(255,255,255,0.8); border: 1px solid rgba(255,255,255,0.3); border-radius: 20px; padding: 5px 14px; }

  /* Process — interactive tabs */
  .process-track { display: flex; position: relative; margin-bottom: 32px; gap: 0; }
  .process-line { position: absolute; top: 18px; left: 18px; right: 18px; height: 1px; background: rgba(255,255,255,0.5); z-index: 0; }
  .ps-step { flex: 1; background: none; border: none; cursor: pointer; display: flex; flex-direction: column; align-items: center; gap: 10px; padding: 0 8px 0; position: relative; z-index: 1; }
  .ps-dot { width: 12px; height: 12px; border-radius: 50%; background: rgba(255,255,255,0.5); border: 2px solid rgba(255,255,255,0.6); transition: all 0.2s; flex-shrink: 0; }
  .ps-step.active .ps-dot, .ps-step:hover .ps-dot { background: var(--teal); border-color: var(--teal); box-shadow: 0 0 0 4px rgba(6,113,129,0.3); }
  .ps-step-num { font-size: 11px; color: rgba(255,255,255,0.75); font-weight: 600; transition: color 0.2s; }
  .ps-step.active .ps-step-num, .ps-step:hover .ps-step-num { color: var(--teal); }
  .ps-step-title { font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.85); text-align: center; transition: color 0.2s; line-height: 1.3; }
  .ps-step.active .ps-step-title, .ps-step:hover .ps-step-title { color: #fff; }


  .process-detail { display: flex; gap: 24px; align-items: flex-start; background: rgba(6,113,129,0.18); border: 1px solid rgba(6,113,129,0.5); border-radius: 12px; padding: 28px 32px; }
  .pd-num { font-size: 48px; font-weight: 700; color: var(--teal); opacity: 0.6; line-height: 1; flex-shrink: 0; }
  .pd-title { font-size: 18px; font-weight: 600; color: #ffffff; margin-bottom: 8px; }
  .pd-desc { font-size: 14px; color: #ffffff; line-height: 1.65; }

  /* Examples */
  .examples-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .ex-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 32px; display: flex; flex-direction: column; gap: 16px; transition: all 0.25s; }
  .ex-card:hover { border-color: rgba(6,113,129,0.4); transform: translateY(-3px); box-shadow: 0 20px 40px rgba(0,0,0,0.3); }
  .ex-card-top { height: 100px; display: flex; align-items: center; justify-content: flex-start; }
  .ex-logo-wrap { background: #fff; border-radius: 10px; padding: 14px 20px; display: inline-flex; }
  .ex-logo { max-height: 44px; max-width: 160px; object-fit: contain; }
  .ex-card-top--photos { position: relative; height: 160px; border-radius: 10px; overflow: hidden; }
  .ex-photo { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: opacity 0.45s; border-radius: 10px; }
  .ex-photo--2 { opacity: 0; }
  .ex-card-top--photos:hover .ex-photo--2 { opacity: 1; }
  .ex-card-top--photos:hover .ex-photo--1 { opacity: 0; }
  .ex-tag { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--teal); font-weight: 600; }
  .ex-name { font-size: 20px; font-weight: 700; color: #fff; margin: 0; }
  .ex-desc { font-size: 14px; color: rgba(255,255,255,0.8); line-height: 1.7; margin: 0; flex: 1; }
  .ex-link { font-size: 13px; color: #fff; text-decoration: none; font-weight: 700; align-self: flex-start; background: rgba(6,113,129,0.5); border: 1px solid var(--teal); padding: 6px 14px; border-radius: 16px; transition: all 0.2s; }
  .ex-link:hover { background: var(--teal); }
  .ex-quote { border-left: 2px solid var(--teal); margin: 0 0 16px; padding: 12px 16px; font-size: 13px; color: rgba(255,255,255,0.78); font-style: italic; line-height: 1.6; }
  .ex-quote cite { display: block; font-style: normal; font-size: 11px; color: var(--teal); margin-top: 6px; font-weight: 600; }
</style>

<script>
  const STEPS = [
    { title: 'Scouting', desc: 'AIR Lab identifies high-potential startups with solutions relevant to ATM challenges.' },
    { title: 'Use Case Development', desc: 'Use case curation & presentation of proposal to a panel from AIR Lab & CAAS.' },
    { title: 'Initial POC', desc: 'For 1st 3 months to demonstrate that the solution can integrate to AIR Lab\'s platform through open APIs.' },
    { title: 'Extended Validation', desc: 'To further prove solution\'s accuracy & resolution; which requires more computing power.' },
    { title: 'AIRspace Hub', desc: 'To facilitate further growth – showcasing their validated solution to other ATM stakeholders.' },
  ];
  const detail = document.getElementById('processDetail');
  function showStep(idx: number) {
    if (detail) detail.innerHTML = `<div style="font-size:48px;font-weight:700;color:var(--teal);opacity:0.6;line-height:1;flex-shrink:0">${idx + 1}</div><div><div style="font-size:18px;font-weight:600;color:#ffffff;margin-bottom:8px">${STEPS[idx].title}</div><div style="font-size:14px;color:#ffffff;line-height:1.65">${STEPS[idx].desc}</div></div>`;
  }
  showStep(0);
  document.querySelectorAll<HTMLElement>('.ps-step').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = Number(btn.dataset.idx);
      document.querySelectorAll('.ps-step').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      showStep(idx);
    });
  });

  // ── Ecosystem wheel ──
  const ECO_DATA: Record<string, { title: string; items?: string[]; tags?: string[] }> = {
    research: {
      title: 'Research Topics',
      items: [
        'Enhancing Automatic Speech Recognition (ASR) in Air Traffic Communications',
        'Predicting Top-of-Descent for CDO Flights using Machine Learning (ML)',
        'Trial regional decentralized FF-ICE optimization model',
      ]
    },
    academia: {
      title: 'Universities & Research Institutes',
      items: [
        'Institute for Infocomm Research (I2R)',
        'Nanyang Technological University — Air Traffic Management Research Institute (ATMRI)',
        'Aviation Systems International (ASI)',
      ]
    },
    usecases: {
      title: 'Use Cases',
      items: [
        'Weather Precipitation Forecast — Meteomatics SING1K',
        'Data Exchange APIs for pilots & controllers to exchange ETA, trajectory and local information',
        'Decentralised user management between ATMs of two regional ANSPs using blockchain technology',
      ]
    },
    industry: {
      title: 'Industry Partners & Startups',
      tags: ['HeLa', 'Meteomatics', 'Skysoft', 'MITRE', 'IMDA'],
    }
  };

  const ecoDetail = document.getElementById('ecoDetail');
  document.querySelectorAll<HTMLElement>('.eco-node').forEach(node => {
    node.addEventListener('click', () => {
      const key = node.dataset.eco!;
      document.querySelectorAll('.eco-node').forEach(n => n.classList.remove('active'));
      node.classList.add('active');
      const d = ECO_DATA[key];
      if (!ecoDetail) return;
      let html = `<div><div style="font-size:16px;font-weight:700;color:#ffffff;margin-bottom:14px">${d.title}</div>`;
      if (d.items) {
        html += `<ul style="margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:8px">`;
        d.items.forEach(item => {
          html += `<li style="font-size:13px;color:#ffffff;line-height:1.65;padding-left:16px;position:relative"><span style="position:absolute;left:0;top:7px;width:5px;height:5px;border-radius:50%;background:var(--teal);display:inline-block"></span>${item}</li>`;
        });
        html += `</ul>`;
      }
      if (d.tags) {
        html += `<div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:4px">`;
        d.tags.forEach(tag => {
          html += `<span style="font-size:12px;font-weight:600;color:#fff;background:rgba(6,113,129,0.3);border:1px solid rgba(6,113,129,0.5);border-radius:20px;padding:5px 14px">${tag}</span>`;
        });
        html += `</div>`;
      }
      html += `</div>`;
      ecoDetail.innerHTML = html;
    });
  });
</script>
