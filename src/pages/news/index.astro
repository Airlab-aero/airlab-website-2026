---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { client, newsListQuery, imageUrl } from '../../lib/sanity';

const articles = await client.fetch(newsListQuery);
const categories = ['All', ...Array.from(new Set(articles.map((a: any) => a.category).filter(Boolean)))];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Fallback images for articles whose WordPress URLs are broken
const LOCAL_COVERS: Record<string, string> = {
  'successful-cdo-simulation-trials': `${base}/images/news/cdo-simulation.png`,
};

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Base title="News" description="The latest news, research highlights, and announcements from AIR Lab Singapore.">
  <Nav slot="nav" />

  <div class="page-hero">
    <div class="page-hero-content">
      <div class="section-label">Latest from AIR Lab</div>
      <h1>News &amp;<br><strong>updates</strong></h1>
      <p>Research breakthroughs, partnerships, events, and team highlights from the AIR Lab ecosystem.</p>
    </div>
  </div>

  <section style="background: var(--off-white);">
    <div class="filter-tabs">
      {categories.map((cat: string) => (
        <button class={`filter-tab${cat === 'All' ? ' active' : ''}`} data-cat={cat}>{cat}</button>
      ))}
    </div>
    <div class="news-grid" id="news-grid">
      {articles.map((article: any) => (
        <div class="news-card" data-cat={article.category} data-date={article.publishedAt ?? ''} style="background: #fff; border-color: var(--border);">
          {(LOCAL_COVERS[article.slug?.current] || article.coverImageUrl || article.coverImage) && (
            <img
              class="news-img"
              src={LOCAL_COVERS[article.slug?.current] || article.coverImageUrl || imageUrl(article.coverImage, 600)}
              alt={article.title}
              loading="lazy"
            />
          )}
          <div class="news-content">
            <span class="news-tag" style="color: var(--red);">{article.category}</span>
            {article.externalUrl ? (
              <a href={article.externalUrl} target="_blank" rel="noopener" class="news-title" style="color: var(--navy);">
                {article.title}
              </a>
            ) : (
              <a href={`${base}/news/${article.slug.current}`} class="news-title" style="color: var(--navy);">
                {article.title}
              </a>
            )}
            <p class="news-excerpt" style="color: var(--muted);">{article.excerpt}</p>
            <span class="news-date" style="color: var(--muted); opacity: 0.7;">{formatDate(article.publishedAt)}</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  .filter-tabs { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 32px; }
  .filter-tab { background: #fff; border: 1px solid var(--border); border-radius: 20px; padding: 7px 18px; font-size: 13px; color: var(--muted); cursor: pointer; transition: all 0.2s; font-family: var(--font); }
  .filter-tab:hover { border-color: var(--teal); color: var(--teal); }
  .filter-tab.active { background: var(--navy); border-color: var(--navy); color: #fff; }
  .news-card { background: #fff; }
  .news-tag { color: var(--red) !important; }
  .news-title { color: var(--navy) !important; }
  .news-title:hover { color: var(--teal) !important; }
  .news-excerpt { color: var(--muted) !important; }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
  const grid = document.getElementById('news-grid')!;
  const allCards = Array.from(document.querySelectorAll<HTMLElement>('.news-card[data-cat]'));

  function applyFilter(cat: string) {
    tabs.forEach(t => t.classList.remove('active'));
    document.querySelector<HTMLButtonElement>(`.filter-tab[data-cat="${cat}"]`)?.classList.add('active');

    const visible = allCards.filter(c => cat === 'All' || c.dataset.cat === cat);
    const hidden  = allCards.filter(c => cat !== 'All' && c.dataset.cat !== cat);

    // Sort visible cards by date descending (date stored in data-date attr)
    visible.sort((a, b) => {
      const da = a.dataset.date ?? '';
      const db = b.dataset.date ?? '';
      return db.localeCompare(da);
    });

    // Re-append visible cards in sorted order, hide the rest
    hidden.forEach(c => { c.style.display = 'none'; });
    visible.forEach(c => { c.style.display = ''; grid.appendChild(c); });
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => applyFilter(tab.dataset.cat ?? 'All'));
  });
</script>
