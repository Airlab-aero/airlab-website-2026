<script>
  function initCarousel(containerId: string, prevId: string, nextId: string) {
    const container = document.getElementById(containerId);
    if (!container) return;
    const slides = Array.from(container.querySelectorAll<HTMLElement>('.ria-slide'));
    const dots = Array.from(container.querySelectorAll<HTMLButtonElement>('.ria-dot'));
    let current = 0;

    function goTo(idx: number) {
      slides[current].classList.remove('active');
      dots[current]?.classList.remove('active');
      current = (idx + slides.length) % slides.length;
      slides[current].classList.add('active');
      dots[current]?.classList.add('active');
    }

    document.getElementById(prevId)?.addEventListener('click', () => goTo(current - 1));
    document.getElementById(nextId)?.addEventListener('click', () => goTo(current + 1));
    dots.forEach(dot => dot.addEventListener('click', () => goTo(Number(dot.dataset.dot))));
  }

  initCarousel('workshopCarousel', 'carouselPrev', 'carouselNext');

  // ── Events: photo carousel + vertical list navigation ──
  (function() {
    const container = document.getElementById('eventsCarousel');
    const track     = document.getElementById('evListTrack');
    const scroller  = track?.parentElement as HTMLElement | null;
    if (!container || !track || !scroller) return;

    const VISIBLE   = 3;
    const slides    = Array.from(container.querySelectorAll<HTMLElement>('.ria-slide'));
    const dots      = Array.from(container.querySelectorAll<HTMLButtonElement>('[data-ev-dot]'));
    const cards     = Array.from(document.querySelectorAll<HTMLElement>('.ria-event[data-ev-idx]'));
    const btnUp     = document.getElementById('evListUp') as HTMLButtonElement;
    const btnDown   = document.getElementById('evListDown') as HTMLButtonElement;
    const counter   = document.getElementById('evListCounter');

    let currentSlide = 0;
    let listOffset   = 0; // which card is first visible

    // ── Vertical list scroll ──────────────────────────────────────────────────
    function updateList() {
      const gap = 12;
      const cardH = (cards[0]?.offsetHeight ?? 110) + gap;
      const visibleH = Math.min(VISIBLE, cards.length) * cardH - gap;
      scroller.style.height = `${visibleH}px`;
      track.style.transform = `translateY(-${listOffset * cardH}px)`;

      btnUp.disabled   = listOffset === 0;
      btnDown.disabled = listOffset >= cards.length - VISIBLE;
      if (counter) counter.textContent =
        `${listOffset + 1}–${Math.min(listOffset + VISIBLE, cards.length)} / ${cards.length}`;
    }

    btnUp?.addEventListener('click',   () => { listOffset = Math.max(0, listOffset - 1); updateList(); });
    btnDown?.addEventListener('click', () => { listOffset = Math.min(cards.length - VISIBLE, listOffset + 1); updateList(); });

    // ── Photo carousel ────────────────────────────────────────────────────────
    function activateSlide(idx: number) {
      slides[currentSlide].classList.remove('active');
      currentSlide = (idx + slides.length) % slides.length;
      slides[currentSlide].classList.add('active');

      const evIdx = Number(slides[currentSlide].dataset.ev);
      dots.forEach(d => d.classList.remove('active'));
      dots[evIdx]?.classList.add('active');
      cards.forEach(c => c.classList.remove('ria-event--active'));
      cards[evIdx]?.classList.add('ria-event--active');

      // Scroll list to keep active card visible
      if (evIdx < listOffset || evIdx >= listOffset + VISIBLE) {
        listOffset = Math.min(Math.max(0, evIdx - 1), cards.length - VISIBLE);
        updateList();
      }
    }

    function goToEvent(evIdx: number) {
      const first = slides.findIndex(s => Number(s.dataset.ev) === evIdx);
      if (first >= 0) activateSlide(first);
    }

    document.getElementById('evCarouselPrev')?.addEventListener('click', () => activateSlide(currentSlide - 1));
    document.getElementById('evCarouselNext')?.addEventListener('click', () => activateSlide(currentSlide + 1));
    dots.forEach(d => d.addEventListener('click', () => goToEvent(Number(d.dataset.evDot))));
    cards.forEach(c => c.addEventListener('click', () => goToEvent(Number(c.dataset.evIdx))));

    // Init after layout
    requestAnimationFrame(updateList);
  })();
</script>
