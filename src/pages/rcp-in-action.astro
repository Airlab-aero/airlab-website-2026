---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// ─── Section 1: Workshops & Working Groups ─────────────────────────────────────
interface ProcessStep { num: string; title: string; desc: string; }
const PROCESS_STEPS: ProcessStep[] = [
  {
    num: '01',
    title: 'Workshop',
    desc: 'AIR Lab convenes ANSPs for focused working sessions. These workshops surface operational pain points, align on regional ATM challenges, and build the shared vocabulary needed for effective collaboration.',
  },
  {
    num: '02',
    title: 'Use case definition',
    desc: 'Participants define concrete use cases with clear operational value, trajectory sharing, capacity forecasting, FF-ICE onboarding, weather integration. Each use case is scoped, prioritised, and assigned to a dedicated working group.',
  },
  {
    num: '03',
    title: 'Technical onboarding',
    desc: 'ANSPs connect to the RCP environment with direct support from AIR Lab engineers. Data feeds are integrated, interfaces validated, and teams trained on the platform\'s tools and open APIs.',
  },
  {
    num: '04',
    title: 'Co-development & iteration',
    desc: 'Working groups test and refine platform features, feedback loops between operations and engineering drive rapid iteration toward validated, deployment-ready capabilities.',
  },
];

// Drop photos in public/images/rcp-in-action/workshops/ and update src fields below.
interface WorkshopPhoto { src: string; caption: string; meta?: string; }
const PHOTOS: WorkshopPhoto[] = [
  { src: 'rcp-in-action/events/vatm-workshop.jpg',          caption: 'VATM Workshop',            meta: 'Vietnam · 2025' },
  { src: 'rcp-in-action/events/asw-hk-2025.jpg',            caption: 'Airspace World Hong Kong',  meta: 'Hong Kong · 2025' },
  { src: 'rcp-in-action/events/singapore-airshow-2026.jpg',  caption: 'Singapore Airshow',         meta: 'Singapore · Feb 2026' },
  { src: 'rcp-in-action/events/asw-lisbon-2026.jpg',         caption: 'Airspace World Lisbon',     meta: 'Lisbon · Mar 2026' },
  { src: 'rcp-in-action/events/aoic-2026.jpg',               caption: 'AOIC 2026',                 meta: '2026' },
];

// ─── Section 2: Technical Backbone ────────────────────────────────────────────
interface TechPillar { title: string; description: string; }

const TECH_PILLARS: TechPillar[] = [
  { title: '[TO FILL]', description: '[TO FILL: 2-3 sentences describing this technical capability]' },
  { title: '[TO FILL]', description: '[TO FILL: 2-3 sentences describing this technical capability]' },
  { title: '[TO FILL]', description: '[TO FILL: 2-3 sentences describing this technical capability]' },
];

const TECH_ICONS = [
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M6.3 6.3a8 8 0 0 0 0 11.4M17.7 6.3a8 8 0 0 1 0 11.4"/><path d="M3.5 3.5a14 14 0 0 0 0 17M20.5 3.5a14 14 0 0 1 0 17"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="2"/><circle cx="5" cy="19" r="2"/><circle cx="19" cy="19" r="2"/><path d="M12 7v5.5M12 12.5l-5.2 5M12 12.5l5.2 5"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M17.5 14v3.5H21M14 17.5h3.5M17.5 21v-3.5"/></svg>`,
];

// ─── Events ───────────────────────────────────────────────────────────────────
interface RCPEvent {
  name: string;
  date: string;
  location: string;
  description: string;
  upcoming?: boolean;
  link?: string;
  linkedin?: string;
  photos?: string[];
}

const EVENTS: RCPEvent[] = [
  // Most recent first
  {
    name: 'Airspace World Lisbon',
    date: 'Mar 2026',
    location: 'Lisbon, Portugal',
    description: 'AIR Lab presented the RCP programme at Airspace World Lisbon, connecting with leading ANSPs, airlines, and technology partners worldwide.',
    photos: ['rcp-in-action/events/asw-lisbon-2026.jpg', 'rcp-in-action/events/asw-lisbon-2026-2.jpg', 'rcp-in-action/events/asw-lisbon-2026-3.jpg'],
  },
  {
    name: 'AOIC 2026',
    date: 'Feb 2026',
    location: 'Singapore',
    description: 'AIR Lab participated in AOIC 2026, sharing the latest developments of the Regional Collaboration Platform with operators and stakeholders across the region.',
    photos: ['rcp-in-action/events/aoic-2026.jpg'],
  },
  {
    name: 'Singapore Airshow',
    date: 'Feb 2026',
    location: 'Singapore',
    description: 'AIR Lab showcased the Regional Collaboration Platform at Singapore Airshow 2026, one of Asia\'s most prominent aviation events.',
    photos: ['rcp-in-action/events/singapore-airshow-2026.jpg', 'rcp-in-action/events/singapore-airshow-2026-2.jpg'],
  },
  {
    name: 'Airspace World Hong Kong',
    date: 'Dec 2025',
    location: 'Hong Kong',
    description: 'AIR Lab joined the global ATM community at Airspace World Hong Kong, presenting the RCP and engaging with ANSP partners from across the region.',
    photos: ['rcp-in-action/events/asw-hk-2025.jpg', 'rcp-in-action/events/asw-hk-2025-2.jpg', 'rcp-in-action/events/asw-hk-2025-3.jpg'],
  },
  {
    name: 'VATM Workshop',
    date: '2025',
    location: 'Vietnam',
    description: 'AIR Lab met with VATM to explore regional data sharing and align on ATM collaboration priorities within the South East Asia corridor.',
    photos: ['rcp-in-action/events/vatm-workshop.jpg'],
  },
];

// Flat list of all slides (for carousel rendering)
const EVENT_SLIDES = EVENTS.flatMap((ev, evIdx) =>
  (ev.photos ?? []).map(photo => ({ photo, ev, evIdx }))
);

// ─── Section 4: ANSP & Partner Network ────────────────────────────────────────
// Drop logo files in public/images/logos/ and set the image filename below.
interface PartnerLogo { name: string; image: string; link?: string; }

const LOGOS: PartnerLogo[] = [
  { name: '[TO FILL]', image: 'logo-1.png' },
  { name: '[TO FILL]', image: 'logo-2.png' },
  { name: '[TO FILL]', image: 'logo-3.png' },
  { name: '[TO FILL]', image: 'logo-4.png' },
  { name: '[TO FILL]', image: 'logo-5.png' },
  { name: '[TO FILL]', image: 'logo-6.png' },
];
---

<Base title="RCP in Action — AIR Lab" description="How AIR Lab drives the Regional Collaboration Platform through workshops, working groups, technical expertise, and a growing ANSP partner network across South East Asia.">
  <Nav slot="nav" />

  <!-- HERO -->
  <div class="ria-hero">
    <div class="ria-hero-tag">Regional Collaboration Platform</div>
    <h1>RCP <strong>in Action</strong></h1>
    <p>From workshops and working groups to a growing technical backbone. AIR Lab puts the RCP to work across South East Asia.</p>
  </div>

  <!-- ── 1. Workshops & Working Groups ────────────────────────────────────── -->
  <section class="ria-section ria-workshops-section">
    <div class="ria-section-head">
      <div class="section-label">01 Workshops &amp; Working Groups</div>
      <h2 class="ria-section-title">How we work<br><strong>together</strong></h2>
    </div>
    <div class="ria-process-layout">

      <!-- Process steps -->
      <div class="ria-steps">
        {PROCESS_STEPS.map((step, i) => (
          <div class="ria-step">
            <div class="ria-step-left">
              <div class="ria-step-num">{step.num}</div>
              {i < PROCESS_STEPS.length - 1 && <div class="ria-step-line"></div>}
            </div>
            <div class="ria-step-content">
              <div class="ria-step-title">{step.title}</div>
              <p class="ria-step-desc">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Photo carousel -->
      <div class="ria-carousel" id="workshopCarousel">
        <div class="ria-carousel-viewport">
          <div class="ria-carousel-track" id="carouselTrack">
            {PHOTOS.map((p, i) => (
              <div class={`ria-slide ${i === 0 ? 'active' : ''}`} data-index={i}>
                <div class="ria-slide-img">
                  <img src={`${base}/images/${p.src}`} alt={p.caption}
                    onerror="this.parentElement.classList.add('ria-slide-placeholder')" />
                </div>
                <div class="ria-slide-caption">
                  <p class="ria-slide-text">{p.caption}</p>
                  {p.meta && <span class="ria-slide-meta">{p.meta}</span>}
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="ria-carousel-controls">
          <button class="ria-carousel-btn" id="carouselPrev" aria-label="Photo précédente">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M10 3L5 8l5 5"/></svg>
          </button>
          <div class="ria-carousel-dots" id="carouselDots">
            {PHOTOS.map((_, i) => (
              <button class={`ria-dot ${i === 0 ? 'active' : ''}`} data-dot={i} aria-label={`Photo ${i + 1}`}></button>
            ))}
          </div>
          <button class="ria-carousel-btn" id="carouselNext" aria-label="Photo suivante">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 3l5 5-5 5"/></svg>
          </button>
        </div>
      </div>

    </div>
  </section>

  <!-- ── Events ───────────────────────────────────────────────────────────── -->
  <section class="ria-section ria-events-section">
    <div class="ria-section-head">
      <div class="section-label">Key Moments</div>
      <h2 class="ria-section-title">Events &amp; <strong>key moments</strong></h2>
    </div>
    <div class="ria-process-layout">

      <!-- Event list -->
      <div>
        <div class="ria-events-scroller">
        <div class="ria-events-list" id="evListTrack">
          {EVENTS.map((ev, evIdx) => (
            <div class={`ria-event ${evIdx === 0 ? 'ria-event--active' : ''}`} data-ev-idx={evIdx}>
              <div class="ria-event-date">{ev.date}</div>
              <div class="ria-event-body">
                <div class="ria-event-name">
                  {ev.name}
                  {ev.upcoming && <span class="ria-upcoming-badge">Upcoming</span>}
                </div>
                <div class="ria-event-loc">{ev.location}</div>
                <p class="ria-event-desc">{ev.description}</p>
              </div>
              <div class="ria-event-actions">
                <a href={ev.linkedin ?? 'https://www.linkedin.com/company/airlab-aero/'} class="ria-event-linkedin" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" onclick="event.stopPropagation()">
                  <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                    <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14ZM7.12 20.45H3.55V9h3.57v11.45Z"/>
                  </svg>
                </a>
                {ev.link && (
                  <a href={ev.link} class="ria-event-link" target="_blank" rel="noopener noreferrer" onclick="event.stopPropagation()">Learn more →</a>
                )}
              </div>
            </div>
          ))}
        </div>
        </div><!-- end ria-events-scroller -->
        <div class="ria-events-list-nav">
          <button class="ria-list-nav-btn" id="evListUp" aria-label="Plus récents" disabled>
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 10l4-4 4 4"/></svg>
          </button>
          <span class="ria-list-nav-counter" id="evListCounter"></span>
          <button class="ria-list-nav-btn" id="evListDown" aria-label="Plus anciens">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6l4 4 4-4"/></svg>
          </button>
        </div>
        <div class="ria-events-cta">
          <p>Want to participate in a workshop or working group?</p>
          <a href={`${base}/contact`} class="btn-navy">Get in touch</a>
        </div>
      </div>

      <!-- Event photos carousel -->
      <div class="ria-carousel" id="eventsCarousel">
        <div class="ria-carousel-viewport">
          <div class="ria-carousel-track">
            {EVENT_SLIDES.map(({ photo, ev, evIdx }, slideIdx) => (
              <div class={`ria-slide ${slideIdx === 0 ? 'active' : ''}`} data-ev={evIdx}>
                <div class="ria-slide-img">
                  <img src={`${base}/images/${photo}`} alt={ev.name}
                    onerror="this.parentElement.classList.add('ria-slide-placeholder')" />
                </div>
                <div class="ria-slide-caption">
                  <p class="ria-slide-text">{ev.name}</p>
                  <span class="ria-slide-meta">{ev.date} · {ev.location}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="ria-carousel-controls">
          <button class="ria-carousel-btn" id="evCarouselPrev" aria-label="Photo précédente">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M10 3L5 8l5 5"/></svg>
          </button>
          <div class="ria-carousel-dots" id="evCarouselDots">
            {EVENTS.map((ev, evIdx) => (
              <button class={`ria-dot ${evIdx === 0 ? 'active' : ''}`} data-ev-dot={evIdx} aria-label={ev.name}></button>
            ))}
          </div>
          <button class="ria-carousel-btn" id="evCarouselNext" aria-label="Photo suivante">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 3l5 5-5 5"/></svg>
          </button>
        </div>
      </div>

    </div>
  </section>

  <!-- ── 2. Technical Backbone ─────────────────────────────────────────────── -->
  <section class="ria-section ria-tech-section">
    <div class="ria-tech-inner">
      <div class="ria-section-head ria-section-head--centered">
        <div class="section-label">02 Technical Backbone</div>
        <h2 class="ria-section-title">The infrastructure<br><strong>behind the platform</strong></h2>
        <p class="ria-tech-intro">[TO FILL: 2-3 sentences introducing AIR Lab's technical expertise and the RCP architecture at a high level]</p>
      </div>
      <div class="ria-pillars-grid">
        {TECH_PILLARS.map((p, i) => (
          <div class="ria-pillar">
            <div class="ria-pillar-icon" set:html={TECH_ICONS[i]}></div>
            <div class="ria-pillar-title">{p.title}</div>
            <p class="ria-pillar-desc">{p.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 4. ANSP & Partner Network ─────────────────────────────────────── -->
  <section class="ria-section ria-logos-section">
    <div class="ria-section-head ria-section-head--centered">
      <div class="section-label">04 ANSP &amp; Partner Network</div>
      <h2 class="ria-section-title">Our partner<br><strong>ecosystem</strong></h2>
    </div>
    <div class="ria-logos-grid">
      {LOGOS.map(l => (
        l.link
          ? <a href={l.link} class="ria-logo-item" target="_blank" rel="noopener noreferrer" title={l.name}>
              <img src={`${base}/images/logos/${l.image}`} alt={l.name} />
            </a>
          : <div class="ria-logo-item" title={l.name}>
              <img src={`${base}/images/logos/${l.image}`} alt={l.name} />
            </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <div class="ria-cta">
    <div class="section-label">Get involved</div>
    <h2 class="section-title" style="color:#fff;margin-top:8px">Ready to collaborate<br><strong>on the platform?</strong></h2>
    <p>Whether you're an ANSP, airline, or research institution, reach out to explore how your organisation can engage with the RCP programme.</p>
    <div class="ria-cta-btns">
      <a href={`${base}/contact`} class="btn-primary">Contact AIR Lab</a>
      <a href={`${base}/partners`} class="btn-ghost">Our Partners</a>
    </div>
  </div>

  <Footer slot="footer" />
</Base>

<style>
  /* ── Hero ──────────────────────────────────────────────────────────────────── */
  .ria-hero {
    background: var(--navy);
    padding: 80px 80px 72px;
    position: relative;
    overflow: hidden;
  }
  .ria-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 75% 50%, rgba(6,113,129,0.08), transparent 60%);
  }
  .ria-hero-tag {
    display: inline-block;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--teal);
    border: 1px solid rgba(6,113,129,0.4);
    padding: 3px 10px;
    border-radius: 4px;
    margin-bottom: 20px;
  }
  .ria-hero h1 {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 300;
    color: #fff;
    line-height: 1.1;
    margin-bottom: 16px;
  }
  .ria-hero h1 strong { font-weight: 700; }
  .ria-hero p {
    font-size: 16px;
    color: rgba(255,255,255,0.55);
    max-width: 520px;
    line-height: 1.7;
    font-weight: 300;
  }

  /* ── Shared section layout ─────────────────────────────────────────────────── */
  .ria-section { padding: 80px 80px; }
  .ria-section-head { margin-bottom: 48px; }
  .ria-section-head--centered { text-align: center; }
  .ria-section-title {
    font-size: clamp(28px, 3.5vw, 42px);
    font-weight: 300;
    color: var(--navy);
    line-height: 1.2;
    margin-top: 8px;
  }
  .ria-section-title strong { font-weight: 700; }

  /* ── Section 1: Workshops ──────────────────────────────────────────────────── */
  .ria-workshops-section { background: #fff; }

  .ria-process-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  /* Steps */
  .ria-steps { display: flex; flex-direction: column; }
  .ria-step { display: flex; gap: 20px; }
  .ria-step-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }
  .ria-step-num {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--navy);
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    letter-spacing: 0.05em;
  }
  .ria-step-line {
    width: 1px;
    flex: 1;
    min-height: 28px;
    background: var(--border);
    margin: 6px 0;
  }
  .ria-step-content { padding-bottom: 36px; }
  .ria-step-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 8px;
    padding-top: 8px;
  }
  .ria-step-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.75;
  }

  /* Carousel */
  .ria-carousel { position: sticky; top: 100px; }
  .ria-carousel-viewport {
    border-radius: 12px;
    overflow: hidden;
    background: var(--navy);
    aspect-ratio: 4/3;
    position: relative;
  }
  .ria-carousel-track { position: relative; width: 100%; height: 100%; }
  .ria-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.4s ease;
    display: flex;
    flex-direction: column;
  }
  .ria-slide.active { opacity: 1; }
  .ria-slide-img {
    flex: 1;
    overflow: hidden;
    background: linear-gradient(135deg, #0b1a2f 0%, #112240 60%, #0d2137 100%);
  }
  .ria-slide-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ria-slide-img.ria-slide-placeholder img { display: none; }
  .ria-slide-caption {
    padding: 14px 18px;
    background: var(--navy);
    flex-shrink: 0;
  }
  .ria-slide-text {
    font-size: 13px;
    color: rgba(255,255,255,0.85);
    line-height: 1.5;
    margin-bottom: 4px;
  }
  .ria-slide-meta {
    font-size: 11px;
    color: var(--teal);
    font-weight: 600;
    letter-spacing: 0.05em;
  }
  .ria-carousel-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 14px;
  }
  .ria-carousel-btn {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: #fff;
    color: var(--navy);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, border-color 0.15s;
    flex-shrink: 0;
  }
  .ria-carousel-btn:hover { background: var(--navy); color: #fff; border-color: var(--navy); }
  .ria-carousel-btn svg { width: 14px; height: 14px; }
  .ria-carousel-dots { display: flex; gap: 6px; }
  .ria-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--border);
    border: none;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    padding: 0;
  }
  .ria-dot.active { background: var(--navy); transform: scale(1.3); }

  /* ── Section 2: Technical Backbone ────────────────────────────────────────── */
  .ria-tech-section { background: var(--cream); }
  .ria-tech-inner { max-width: 1100px; margin: 0 auto; }
  .ria-tech-intro {
    font-size: 16px;
    color: var(--muted);
    max-width: 600px;
    margin: 16px auto 48px;
    line-height: 1.75;
    text-align: center;
  }

  .ria-pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-bottom: 48px;
  }

  .ria-pillar {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 28px 24px;
  }
  .ria-pillar-icon {
    width: 36px;
    height: 36px;
    color: var(--teal);
    margin-bottom: 16px;
  }
  .ria-pillar-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 10px;
  }
  .ria-pillar-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.7;
  }

  /* ── Events ────────────────────────────────────────────────────────────────── */
  .ria-events-section { background: var(--navy); }

  .ria-events-scroller { overflow: hidden; }
  .ria-events-list { transition: transform 0.35s ease; margin-bottom: 0; }

  .ria-events-list-nav {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 14px 0 0;
  }
  .ria-list-nav-btn {
    width: 32px; height: 32px;
