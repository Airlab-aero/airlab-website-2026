---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// ─── Section 1: Workshops & Working Groups ─────────────────────────────────────
// Drop images in public/images/rcp-in-action/workshops/ and set the `image` field.
type WType = 'Workshop' | 'Working Group' | 'Training' | 'Event';
interface Workshop {
  type: WType;
  title: string;
  date: string;
  location: string;
  description: string;
  image?: string;
}

const WORKSHOPS: Workshop[] = [
  { type: 'Workshop',      title: '[TO FILL]', date: '[TO FILL]', location: '[TO FILL]', description: '[TO FILL — 1 to 2 sentences]' },
  { type: 'Working Group', title: '[TO FILL]', date: '[TO FILL]', location: '[TO FILL]', description: '[TO FILL — 1 to 2 sentences]' },
  { type: 'Training',      title: '[TO FILL]', date: '[TO FILL]', location: '[TO FILL]', description: '[TO FILL — 1 to 2 sentences]' },
  { type: 'Workshop',      title: '[TO FILL]', date: '[TO FILL]', location: '[TO FILL]', description: '[TO FILL — 1 to 2 sentences]' },
  { type: 'Working Group', title: '[TO FILL]', date: '[TO FILL]', location: '[TO FILL]', description: '[TO FILL — 1 to 2 sentences]' },
  { type: 'Workshop',      title: '[TO FILL]', date: '[TO FILL]', location: '[TO FILL]', description: '[TO FILL — 1 to 2 sentences]' },
];

const W_COLOR: Record<WType, string> = {
  Workshop:        'var(--teal)',
  'Working Group': '#7c3aed',
  Training:        '#d97706',
  Event:           '#2563eb',
};

// ─── Section 2: Technical Backbone ────────────────────────────────────────────
interface TechPillar { title: string; description: string; }

const TECH_PILLARS: TechPillar[] = [
  { title: '[TO FILL]', description: '[TO FILL — 2–3 sentences describing this technical capability]' },
  { title: '[TO FILL]', description: '[TO FILL — 2–3 sentences describing this technical capability]' },
  { title: '[TO FILL]', description: '[TO FILL — 2–3 sentences describing this technical capability]' },
];

const TECH_ICONS = [
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M6.3 6.3a8 8 0 0 0 0 11.4M17.7 6.3a8 8 0 0 1 0 11.4"/><path d="M3.5 3.5a14 14 0 0 0 0 17M20.5 3.5a14 14 0 0 1 0 17"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="2"/><circle cx="5" cy="19" r="2"/><circle cx="19" cy="19" r="2"/><path d="M12 7v5.5M12 12.5l-5.2 5M12 12.5l5.2 5"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M17.5 14v3.5H21M14 17.5h3.5M17.5 21v-3.5"/></svg>`,
];

// ─── Section 3: Upcoming Events ────────────────────────────────────────────────
interface UpcomingEvent {
  name: string;
  date: string;
  location: string;
  description: string;
  link?: string;
}

const EVENTS: UpcomingEvent[] = [
  { name: '[TO FILL]', date: '[TO FILL]', location: '[TO FILL]', description: '[TO FILL — 1 to 2 sentences]' },
  { name: '[TO FILL]', date: '[TO FILL]', location: '[TO FILL]', description: '[TO FILL — 1 to 2 sentences]' },
  { name: '[TO FILL]', date: '[TO FILL]', location: '[TO FILL]', description: '[TO FILL — 1 to 2 sentences]' },
];

// ─── Section 4: ANSP & Partner Network ────────────────────────────────────────
// Drop logo files in public/images/logos/ and set the image filename below.
interface PartnerLogo { name: string; image: string; link?: string; }

const LOGOS: PartnerLogo[] = [
  { name: '[TO FILL]', image: 'logo-1.png' },
  { name: '[TO FILL]', image: 'logo-2.png' },
  { name: '[TO FILL]', image: 'logo-3.png' },
  { name: '[TO FILL]', image: 'logo-4.png' },
  { name: '[TO FILL]', image: 'logo-5.png' },
  { name: '[TO FILL]', image: 'logo-6.png' },
];
---

<Base title="RCP in Action — AIR Lab" description="How Air Lab drives the Regional Collaboration Platform through workshops, working groups, technical expertise, and a growing ANSP partner network across South East Asia.">
  <Nav slot="nav" />

  <!-- HERO -->
  <div class="ria-hero">
    <div class="ria-hero-tag">Regional Collaboration Platform</div>
    <h1>RCP <strong>in Action</strong></h1>
    <p>From workshops and working groups to a growing technical backbone — Air Lab puts the RCP to work across South East Asia.</p>
  </div>

  <!-- ── 1. Workshops & Working Groups ────────────────────────────────────── -->
  <section class="ria-section ria-workshops-section">
    <div class="ria-section-head">
      <div class="section-label">01 — Workshops &amp; Working Groups</div>
      <h2 class="ria-section-title">Bringing stakeholders<br><strong>to the table</strong></h2>
    </div>
    <div class="ria-cards-grid">
      {WORKSHOPS.map(w => (
        <div class="ria-card">
          <div class="ria-card-img">
            {w.image
              ? <img src={`${base}/images/rcp-in-action/workshops/${w.image}`} alt={w.title} />
              : <div class="ria-img-placeholder">
                  <svg viewBox="0 0 48 48" fill="none" aria-hidden="true">
                    <path d="M8 36l10-12 7 8 5-6 10 10" stroke="rgba(255,255,255,0.1)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <circle cx="16" cy="18" r="3" stroke="rgba(255,255,255,0.1)" stroke-width="1.5"/>
                  </svg>
                </div>
            }
          </div>
          <div class="ria-card-body">
            <span class="ria-badge" style={`color:${W_COLOR[w.type]}`}>{w.type}</span>
            <div class="ria-card-title">{w.title}</div>
            <p class="ria-card-desc">{w.description}</p>
            <div class="ria-card-meta">
              <span>{w.location}</span>
              <span>{w.date}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── 2. Technical Backbone ─────────────────────────────────────────────── -->
  <section class="ria-section ria-tech-section">
    <div class="ria-tech-inner">
      <div class="ria-section-head ria-section-head--centered">
        <div class="section-label">02 — Technical Backbone</div>
        <h2 class="ria-section-title">The infrastructure<br><strong>behind the platform</strong></h2>
        <p class="ria-tech-intro">[TO FILL — 2–3 sentences introducing Air Lab's technical expertise and the RCP architecture at a high level]</p>
      </div>
      <div class="ria-pillars-grid">
        {TECH_PILLARS.map((p, i) => (
          <div class="ria-pillar">
            <div class="ria-pillar-icon" set:html={TECH_ICONS[i]}></div>
            <div class="ria-pillar-title">{p.title}</div>
            <p class="ria-pillar-desc">{p.description}</p>
          </div>
        ))}
      </div>
      <!-- Replace the placeholder below with an <img> or embedded diagram when ready -->
      <div class="ria-diagram-placeholder">
        <div class="ria-diagram-label">RCP Architecture Diagram</div>
        <div class="ria-diagram-hint">[ Diagram to be inserted ]</div>
      </div>
    </div>
  </section>

  <!-- ── 3. Upcoming Events ──────────────────────────────────────────────── -->
  <section class="ria-section ria-events-section">
    <div class="ria-section-head">
      <div class="section-label" style="color:var(--teal)">03 — Upcoming Events</div>
      <h2 class="ria-section-title" style="color:#fff">What's <strong>coming next</strong></h2>
    </div>
    <div class="ria-events-list">
      {EVENTS.map(ev => (
        <div class="ria-event">
          <div class="ria-event-date">{ev.date}</div>
          <div class="ria-event-body">
            <div class="ria-event-name">{ev.name}</div>
            <div class="ria-event-loc">{ev.location}</div>
            <p class="ria-event-desc">{ev.description}</p>
          </div>
          {ev.link && (
            <a href={ev.link} class="ria-event-cta" target="_blank" rel="noopener noreferrer">Learn more →</a>
          )}
        </div>
      ))}
    </div>
  </section>

  <!-- ── 4. ANSP & Partner Network ─────────────────────────────────────── -->
  <section class="ria-section ria-logos-section">
    <div class="ria-section-head ria-section-head--centered">
      <div class="section-label">04 — ANSP &amp; Partner Network</div>
      <h2 class="ria-section-title">Our partner<br><strong>ecosystem</strong></h2>
    </div>
    <div class="ria-logos-grid">
      {LOGOS.map(l => (
        l.link
          ? <a href={l.link} class="ria-logo-item" target="_blank" rel="noopener noreferrer" title={l.name}>
              <img src={`${base}/images/logos/${l.image}`} alt={l.name} />
            </a>
          : <div class="ria-logo-item" title={l.name}>
              <img src={`${base}/images/logos/${l.image}`} alt={l.name} />
            </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <div class="ria-cta">
    <div class="section-label">Get involved</div>
    <h2 class="section-title" style="color:#fff;margin-top:8px">Ready to collaborate<br><strong>on the platform?</strong></h2>
    <p>Whether you're an ANSP, airline, or research institution — reach out to explore how your organisation can engage with the RCP programme.</p>
    <div class="ria-cta-btns">
      <a href={`${base}/contact`} class="btn-primary">Contact AIR Lab</a>
      <a href={`${base}/partners`} class="btn-ghost">Our Partners</a>
    </div>
  </div>

  <Footer slot="footer" />
</Base>

<style>
  /* ── Hero ──────────────────────────────────────────────────────────────────── */
  .ria-hero {
    background: var(--navy);
    padding: 80px 80px 72px;
    position: relative;
    overflow: hidden;
  }
  .ria-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 75% 50%, rgba(6,113,129,0.08), transparent 60%);
  }
  .ria-hero-tag {
    display: inline-block;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--teal);
    border: 1px solid rgba(6,113,129,0.4);
    padding: 3px 10px;
    border-radius: 4px;
    margin-bottom: 20px;
  }
  .ria-hero h1 {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 300;
    color: #fff;
    line-height: 1.1;
    margin-bottom: 16px;
  }
  .ria-hero h1 strong { font-weight: 700; }
  .ria-hero p {
    font-size: 16px;
    color: rgba(255,255,255,0.55);
    max-width: 520px;
    line-height: 1.7;
    font-weight: 300;
  }

  /* ── Shared section layout ─────────────────────────────────────────────────── */
  .ria-section { padding: 80px 80px; }
  .ria-section-head { margin-bottom: 48px; }
  .ria-section-head--centered { text-align: center; }
  .ria-section-title {
    font-size: clamp(28px, 3.5vw, 42px);
    font-weight: 300;
    color: var(--navy);
    line-height: 1.2;
    margin-top: 8px;
  }
  .ria-section-title strong { font-weight: 700; }

  /* ── Section 1: Workshops ──────────────────────────────────────────────────── */
  .ria-workshops-section { background: #fff; }

  .ria-cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .ria-card {
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .ria-card:hover {
    border-color: var(--teal);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(6,113,129,0.08);
  }

  .ria-card-img {
    width: 100%;
    aspect-ratio: 3/2;
    overflow: hidden;
  }
  .ria-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .ria-card:hover .ria-card-img img { transform: scale(1.04); }

  .ria-img-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #0b1a2f 0%, #112240 60%, #0d2137 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ria-img-placeholder svg { width: 48px; height: 48px; }

  .ria-card-body { padding: 16px 18px 18px; }
  .ria-badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 7px;
  }
  .ria-card-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--navy);
    line-height: 1.35;
    margin-bottom: 7px;
  }
  .ria-card-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.65;
    margin-bottom: 12px;
  }
  .ria-card-meta {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: #aaa;
    padding-top: 10px;
    border-top: 1px solid var(--border);
    font-weight: 500;
  }

  /* ── Section 2: Technical Backbone ────────────────────────────────────────── */
  .ria-tech-section { background: var(--cream); }
  .ria-tech-inner { max-width: 1100px; margin: 0 auto; }
  .ria-tech-intro {
    font-size: 16px;
    color: var(--muted);
    max-width: 600px;
    margin: 16px auto 48px;
    line-height: 1.75;
    text-align: center;
  }

  .ria-pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-bottom: 48px;
  }

  .ria-pillar {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 28px 24px;
  }
  .ria-pillar-icon {
    width: 36px;
    height: 36px;
    color: var(--teal);
    margin-bottom: 16px;
  }
  .ria-pillar-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 10px;
  }
  .ria-pillar-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.7;
  }

  .ria-diagram-placeholder {
    border: 2px dashed var(--border);
    border-radius: 10px;
    padding: 72px 40px;
    text-align: center;
  }
  .ria-diagram-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 8px;
  }
  .ria-diagram-hint {
    font-size: 14px;
    color: #bbb;
    font-style: italic;
  }

  /* ── Section 3: Upcoming Events ────────────────────────────────────────────── */
  .ria-events-section { background: var(--navy); }
  .ria-events-section .ria-section-title { color: #fff; }

  .ria-events-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .ria-event {
    display: grid;
    grid-template-columns: 120px 1fr auto;
    gap: 28px;
    align-items: center;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    padding: 24px 28px;
    transition: border-color 0.2s, background 0.2s;
  }
  .ria-event:hover {
    border-color: rgba(6,113,129,0.4);
    background: rgba(6,113,129,0.04);
  }

  .ria-event-date {
    font-size: 13px;
    font-weight: 700;
    color: var(--teal);
    line-height: 1.5;
    text-align: center;
  }

  .ria-event-name {
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 4px;
  }
  .ria-event-loc {
    font-size: 11px;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin-bottom: 8px;
  }
  .ria-event-desc {
    font-size: 13px;
    color: rgba(255,255,255,0.55);
    line-height: 1.65;
  }

  .ria-event-cta {
    font-size: 12px;
    font-weight: 700;
    color: var(--teal);
    text-decoration: none;
    white-space: nowrap;
    padding: 8px 16px;
    border: 1px solid rgba(6,113,129,0.4);
    border-radius: 6px;
    transition: background 0.2s, border-color 0.2s;
  }
  .ria-event-cta:hover {
    background: rgba(6,113,129,0.15);
    border-color: var(--teal);
  }

  /* ── Section 4: Logo Wall ───────────────────────────────────────────────────── */
  .ria-logos-section { background: #fff; }

  .ria-logos-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    justify-content: center;
    align-items: center;
  }

  .ria-logo-item {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 160px;
    height: 80px;
    padding: 16px;
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    filter: grayscale(1);
    opacity: 0.5;
    transition: filter 0.25s, opacity 0.25s, border-color 0.25s;
  }
  .ria-logo-item:hover {
    filter: grayscale(0);
    opacity: 1;
    border-color: rgba(6,113,129,0.3);
  }
  .ria-logo-item img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    display: block;
  }

  /* ── CTA ───────────────────────────────────────────────────────────────────── */
  .ria-cta { background: var(--navy); padding: 80px; text-align: center; }
  .ria-cta p { font-size: 15px; color: rgba(255,255,255,0.5); max-width: 460px; margin: 16px auto 36px; line-height: 1.7; }
  .ria-cta-btns { display: flex; gap: 16px; justify-content: center; }

  /* ── Responsive ────────────────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .ria-hero, .ria-section, .ria-cta { padding-left: 24px; padding-right: 24px; }
    .ria-hero { padding-top: 60px; padding-bottom: 52px; }
    .ria-cards-grid { grid-template-columns: repeat(2, 1fr); }
    .ria-pillars-grid { grid-template-columns: 1fr; gap: 16px; }
    .ria-event { grid-template-columns: 1fr; gap: 12px; }
    .ria-event-date { text-align: left; }
    .ria-logo-item { width: 120px; height: 64px; }
    .ria-cta-btns { flex-direction: column; align-items: center; }
  }
  @media (max-width: 600px) {
    .ria-cards-grid { grid-template-columns: 1fr; }
  }
</style>
