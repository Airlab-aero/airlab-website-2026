---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="RCP in Action — AIR Lab" description="How Air Lab turns the Regional Collaboration Platform into real engagements across South East Asia — workshops, ANSP partnerships, and technical deployments.">
  <Nav slot="nav" />

  <!-- HERO -->
  <div class="rca-hero">
    <div class="rca-hero-tag">Regional Collaboration Platform</div>
    <h1>RCP <strong>in Action</strong></h1>
    <p>Not just a platform — a programme. Air Lab leads workshops, working groups, and bilateral engagements that put the RCP to work across South East Asia.</p>
    <div class="rca-hero-stats">
      <div class="rca-stat"><span class="rca-stat-num">10+</span><span class="rca-stat-lbl">ANSP partners engaged</span></div>
      <div class="rca-stat"><span class="rca-stat-num">15+</span><span class="rca-stat-lbl">Workshops & working groups</span></div>
      <div class="rca-stat"><span class="rca-stat-num">3</span><span class="rca-stat-lbl">Active bilateral programmes</span></div>
      <div class="rca-stat"><span class="rca-stat-num">5</span><span class="rca-stat-lbl">ANSPs on FF-ICE/R1</span></div>
    </div>
  </div>

  <!-- MAIN CONTENT -->
  <div class="rca-body">

    <div class="rca-columns">

      <!-- Column 1: Workshops -->
      <div class="rca-col">
        <div class="rca-col-header">
          <span class="rca-col-num">01</span>
          <span class="rca-col-label">Workshops &amp; Working Groups</span>
        </div>
        <div class="rca-card">
          <span class="rca-tag">Workshop</span>
          <div class="rca-card-title">SEA FIR Coordination Workshop</div>
          <p class="rca-card-body">Cross-FIR session with 8 ANSPs to align on trajectory sharing procedures and RCP data access protocols.</p>
          <div class="rca-card-meta"><span>Bangkok</span><span>Mar 2025</span></div>
        </div>
        <div class="rca-card">
          <span class="rca-tag">Working Group</span>
          <div class="rca-card-title">FF-ICE Integration Working Group</div>
          <p class="rca-card-body">Review of FF-ICE/R1 procedures and interoperability requirements across participating FIRs.</p>
          <div class="rca-card-meta"><span>Singapore</span><span>Jan 2025</span></div>
        </div>
        <div class="rca-card">
          <span class="rca-tag">Training</span>
          <div class="rca-card-title">CDO Trial Planning Sessions</div>
          <p class="rca-card-body">Pre-study coordination for Continuous Descent Operations simulation trials across three high-traffic city-pair routes.</p>
          <div class="rca-card-meta"><span>Manila</span><span>Nov 2024</span></div>
        </div>
        <div class="rca-card">
          <span class="rca-tag">Workshop</span>
          <div class="rca-card-title">Regional Hotspot Analysis</div>
          <p class="rca-card-body">Capacity planning session using RCP demand forecasting tools to identify saturation risks across peak corridors.</p>
          <div class="rca-card-meta"><span>Kuala Lumpur</span><span>Sep 2024</span></div>
        </div>
        <div class="rca-card">
          <span class="rca-tag">Working Group</span>
          <div class="rca-card-title">Area Avoidance &amp; CDR Working Group</div>
          <p class="rca-card-body">Technical review of conflict detection and resolution procedures integrated into the RCP simulation environment.</p>
          <div class="rca-card-meta"><span>Virtual</span><span>Jul 2024</span></div>
        </div>
      </div>

      <!-- Column 2: Engagements -->
      <div class="rca-col">
        <div class="rca-col-header">
          <span class="rca-col-num">02</span>
          <span class="rca-col-label">ANSP &amp; Partner Engagements</span>
        </div>
        <div class="rca-card">
          <span class="rca-tag rca-tag-active">Active</span>
          <div class="rca-card-title">Civil Aviation Authority of Singapore</div>
          <p class="rca-card-body">Bilateral collaboration on trajectory negotiation trials and FF-ICE/R1 live implementation across Singapore FIR.</p>
          <div class="rca-card-meta"><span>CAAS</span><span>WSSS FIR</span></div>
        </div>
        <div class="rca-card">
          <span class="rca-tag rca-tag-active">Active</span>
          <div class="rca-card-title">DCA Malaysia</div>
          <p class="rca-card-body">Regional health data sharing and route-level hotspot monitoring across Kuala Lumpur FIR.</p>
          <div class="rca-card-meta"><span>DCA</span><span>WMKK FIR</span></div>
        </div>
        <div class="rca-card">
          <span class="rca-tag rca-tag-active">Active</span>
          <div class="rca-card-title">AirNav Indonesia</div>
          <p class="rca-card-body">CDO route optimisation and data pipeline integration across Jakarta and Makassar FIRs.</p>
          <div class="rca-card-meta"><span>AirNav</span><span>WIII FIR</span></div>
        </div>
        <div class="rca-card">
          <span class="rca-tag rca-tag-active">Active</span>
          <div class="rca-card-title">CAAT Thailand</div>
          <p class="rca-card-body">Cross-FIR conflict detection monitoring and shared situational awareness trials with Bangkok ACC.</p>
          <div class="rca-card-meta"><span>CAAT</span><span>VTBB FIR</span></div>
        </div>
        <div class="rca-card">
          <span class="rca-tag">Partner</span>
          <div class="rca-card-title">ICAO APAC &amp; Regional Bodies</div>
          <p class="rca-card-body">Alignment on PBCS implementation and FF-ICE roadmap within the ICAO Asia-Pacific regional framework.</p>
          <div class="rca-card-meta"><span>ICAO APAC</span><span>Regional</span></div>
        </div>
      </div>

      <!-- Column 3: Technical -->
      <div class="rca-col">
        <div class="rca-col-header">
          <span class="rca-col-num">03</span>
          <span class="rca-col-label">Technical Backbone</span>
        </div>
        <div class="rca-card">
          <span class="rca-tag rca-tag-live">Live</span>
          <div class="rca-card-title">FF-ICE/R1 Implementation</div>
          <p class="rca-card-body">End-to-end eAU and eASP services operational across 5 ANSPs. Real-time trajectory negotiation in production.</p>
          <div class="rca-card-meta"><span>5 ANSPs</span><span>SEA Region</span></div>
        </div>
        <div class="rca-card">
          <span class="rca-tag rca-tag-live">Live</span>
          <div class="rca-card-title">Surveillance Data Fusion</div>
          <p class="rca-card-body">10+ surveillance sources fused into a single coherent regional air picture, updated every 4 seconds.</p>
          <div class="rca-card-meta"><span>10+ sources</span><span>4 s refresh</span></div>
        </div>
        <div class="rca-card">
          <span class="rca-tag rca-tag-live">Live</span>
          <div class="rca-card-title">Regional Health Dashboard</div>
          <p class="rca-card-body">Monthly reporting on SEA airspace performance — routes, airports, flight levels, and peak throughput trends.</p>
          <div class="rca-card-meta"><span>Monthly</span><span>SEA Region</span></div>
        </div>
        <div class="rca-card">
          <span class="rca-tag">Research</span>
          <div class="rca-card-title">Fast-Time Simulation Framework</div>
          <p class="rca-card-body">50+ scenarios validated at regional scale — supporting concept evaluation, trial design, and ANSP training.</p>
          <div class="rca-card-meta"><span>50+ scenarios</span><span>ATM Research</span></div>
        </div>
        <div class="rca-card">
          <span class="rca-tag">AI</span>
          <div class="rca-card-title">AI-Driven Trajectory Generator</div>
          <p class="rca-card-body">ML models generating optimised 4D trajectories balancing efficiency, operational constraints, and real-time weather.</p>
          <div class="rca-card-meta"><span>AI / ML</span><span>In development</span></div>
        </div>
      </div>

    </div>
  </div>

  <!-- CTA -->
  <div class="rca-cta">
    <div class="section-label">Get involved</div>
    <h2 class="section-title" style="color:#fff;margin-top:8px">Ready to collaborate<br><strong>on the platform?</strong></h2>
    <p>Whether you're an ANSP, airline, or research institution — reach out to explore how your organisation can engage with the RCP programme.</p>
    <div class="rca-cta-btns">
      <a href={`${base}/contact`} class="btn-primary">Contact AIR Lab</a>
      <a href={`${base}/partners`} class="btn-ghost">Our Partners</a>
    </div>
  </div>

  <Footer slot="footer" />
</Base>

<style>
  .rca-hero { background: var(--navy); padding: 80px 80px 72px; position: relative; overflow: hidden; }
  .rca-hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 75% 50%, rgba(6,113,129,0.08), transparent 60%); }
  .rca-hero-tag { display: inline-block; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--teal); border: 1px solid rgba(6,113,129,0.4); padding: 3px 10px; border-radius: 4px; margin-bottom: 20px; }
  .rca-hero h1 { font-size: clamp(36px, 5vw, 56px); font-weight: 300; color: #fff; line-height: 1.1; margin-bottom: 16px; }
  .rca-hero h1 strong { font-weight: 700; }
  .rca-hero p { font-size: 16px; color: rgba(255,255,255,0.55); max-width: 520px; line-height: 1.7; margin-bottom: 48px; font-weight: 300; }

  .rca-hero-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; overflow: hidden; max-width: 720px; }
  .rca-stat { padding: 24px 28px; border-right: 1px solid rgba(255,255,255,0.08); }
  .rca-stat:last-child { border-right: none; }
  .rca-stat-num { display: block; font-size: 32px; font-weight: 700; color: var(--teal); line-height: 1; margin-bottom: 6px; }
  .rca-stat-lbl { display: block; font-size: 12px; color: rgba(255,255,255,0.45); line-height: 1.4; }

  .rca-body { background: #fff; padding: 80px 80px 80px; }

  .rca-columns { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; align-items: start; }

  .rca-col-header { display: flex; align-items: baseline; gap: 10px; margin-bottom: 20px; padding-bottom: 14px; border-bottom: 2px solid var(--border); }
  .rca-col-num { font-size: 11px; font-weight: 700; letter-spacing: 0.12em; color: var(--teal); }
  .rca-col-label { font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--navy); }

  .rca-card { background: var(--cream); border: 1px solid var(--border); border-radius: 8px; padding: 20px 22px; margin-bottom: 10px; transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s; }
  .rca-card:hover { border-color: var(--teal); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(6,113,129,0.08); }
  .rca-tag { display: inline-block; font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--teal); margin-bottom: 9px; }
  .rca-tag-active { color: #059669; }
  .rca-tag-live { color: #2563eb; }
  .rca-card-title { font-size: 14px; font-weight: 700; color: var(--navy); line-height: 1.35; margin-bottom: 8px; }
  .rca-card-body { font-size: 13px; color: var(--muted); line-height: 1.65; margin-bottom: 12px; }
  .rca-card-meta { display: flex; justify-content: space-between; font-size: 11px; color: #aaa; padding-top: 10px; border-top: 1px solid var(--border); font-weight: 500; }

  .rca-cta { background: var(--navy); padding: 80px; text-align: center; }
  .rca-cta p { font-size: 15px; color: rgba(255,255,255,0.5); max-width: 460px; margin: 16px auto 36px; line-height: 1.7; }
  .rca-cta-btns { display: flex; gap: 16px; justify-content: center; }

  @media (max-width: 900px) {
    .rca-hero, .rca-body, .rca-cta { padding-left: 24px; padding-right: 24px; }
    .rca-hero { padding-top: 60px; padding-bottom: 52px; }
    .rca-hero-stats { grid-template-columns: repeat(2, 1fr); }
    .rca-stat { border-bottom: 1px solid rgba(255,255,255,0.08); }
    .rca-columns { grid-template-columns: 1fr; }
    .rca-cta-btns { flex-direction: column; align-items: center; }
  }
</style>
