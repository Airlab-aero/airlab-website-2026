---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { client, newsListQuery, teamQuery, homePageQuery, imageUrl } from '../lib/sanity';

const news = await client.fetch(newsListQuery);
const latestNews = news.slice(0, 3);
const team = await client.fetch(teamQuery);
const featuredTeam = team.filter((m: any) => imageUrl(m.photo) || m.photoUrl).slice(0, 12);
const cms = await client.fetch(homePageQuery) ?? {};

const heroSubtitle = cms.heroSubtitle ?? 'A free, open-access cloud sandbox where air navigation service providers co-develop, test, and shape the next generation of air traffic management. Together.';
const heroVideoUrl = cms.heroVideoUrl ?? `${base}/vid-hero.mp4`;
const heroPrimaryButtonText = cms.heroPrimaryButtonText ?? 'Access the Platform';
const heroPrimaryButtonUrl = cms.heroPrimaryButtonUrl ?? 'https://rcp-landing-page.rcp.pub.airlab.thalesdigital.io/';
const stats = cms.stats ?? [
  { number: '2019', suffix: '', label: 'Founded by Thales & CAAS\nSingapore' },
  { number: '10', suffix: '+', label: 'APAC ANSPs actively\nengaged on the platform' },
  { number: '100', suffix: '%', label: 'Free access for regional ANSPs,\ncloud-based open-source stack' },
];
const ctaTitle = cms.ctaTitle ?? 'Ready to join the collaboration?';
const ctaSubtitle = cms.ctaSubtitle ?? "Whether you're an ANSP, research institution, or technology provider: the RCP is open for collaboration.";
const ctaLocation = cms.ctaLocation ?? 'AIR Lab @ WeWork, Suntec Tower 5\nTemasek Boulevard, Singapore 038985';
const ctaPlatformUrl = cms.ctaPlatformUrl ?? 'https://rcp-landing-page.rcp.pub.airlab.thalesdigital.io/';
const ctaApiUrl = cms.ctaApiUrl ?? 'https://open-atms.airlab.aero/public-api/';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="AIR Lab — Regional Collaboration Platform" description="A free, open-access cloud sandbox where air navigation service providers co-develop, test, and shape the next generation of air traffic management.">
  <Nav slot="nav" />

  <!-- HERO -->
  <section class="hero" id="top">
    <div class="hero-bg">
      <video id="hero-video" muted loop playsinline preload="auto">
        <source src={heroVideoUrl} type="video/mp4" />
      </video>
    </div>
    <div class="hero-content">
      <div class="hero-tag">By AIR Lab</div>
      <h1>The <strong>Regional Collaboration<br>Platform</strong></h1>
      <p class="hero-sub">{heroSubtitle}</p>
      <div class="hero-actions">
        <a href={heroPrimaryButtonUrl} class="btn-primary" target="_blank">{heroPrimaryButtonText}</a>
        <a href="#platform" class="btn-ghost">Explore the RCP ↓</a>
      </div>
    </div>
    <div class="hero-scroll">Scroll to explore</div>
  </section>

  <!-- STATS STRIP -->
  <div class="about-strip">
    {stats.map((stat: any, i: number) => (
      <div class="about-stat" data-reveal data-reveal-delay={i * 100}>
        <div class="about-stat-num">{stat.number}<span>{stat.suffix}</span></div>
        <div class="about-stat-label" set:html={stat.label.replace(/\n/g, '<br>')}></div>
      </div>
    ))}
  </div>

  <!-- PLATFORM CAPABILITIES -->
  <section class="capabilities" id="platform">
    <div class="cap-bg-img" style={`background-image:url('${base}/digitaltwin.jpg')`}></div>
    <div class="section-header" data-reveal style="text-align:center;">
      <div class="section-label">Regional Collaboration Platform</div>
      <h2 class="section-title">An open sandbox for<br><strong>ATM innovation</strong></h2>
    </div>
    <div class="cap-grid" style="grid-template-columns:repeat(4,1fr);">
      <div class="cap-card" data-reveal data-reveal-delay="0">
        <div class="cap-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="#067181" stroke-width="1.5"><circle cx="12" cy="12" r="9"></circle><path d="M12 3v9l5 3"></path></svg>
        </div>
        <h3>4D Trajectory</h3>
        <p>Real-time flight data enriched with global flight plans and surveillance fusion for accurate situational awareness across the entire APAC region.</p>
        <span class="cap-tag">Live Data</span>
      </div>
      <div class="cap-card" data-reveal data-reveal-delay="80">
        <div class="cap-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="#067181" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5M2 12l10 5 10-5"></path></svg>
        </div>
        <h3>FF-ICE</h3>
        <p>Full FF-ICE/R1 stack enabling collaborative flight planning between airlines and ANSPs, from trajectory negotiation to pre-departure agreement.</p>
        <span class="cap-tag">ICAO Standard</span>
      </div>
      <div class="cap-card" data-reveal data-reveal-delay="160">
        <div class="cap-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="#067181" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect><path d="M14 17h7M17 14v7"></path></svg>
        </div>
        <h3>Open ATM Architecture</h3>
        <p>Integrates data from airlines, airports, and service providers to make the ecosystem smarter, safer, and more connected.</p>
        <span class="cap-tag">Open Source</span>
      </div>
      <div class="cap-card" data-reveal data-reveal-delay="240">
        <div class="cap-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="#067181" stroke-width="1.5"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"></path></svg>
        </div>
        <h3>Fast Time Simulation</h3>
        <p>Accelerated simulation environment enabling ANSPs to test ATM concepts and procedures at scale, running scenarios faster than real-time to validate performance before deployment.</p>
        <span class="cap-tag">Research</span>
      </div>
    </div>
  </section>

  <!-- USE CASES -->
  <section class="use-cases" id="use-cases">
    <div class="uc-header" data-reveal>
      <div class="section-label">Regional Collaboration Platform</div>
      <h2 class="section-title">What you can do<br><strong>on the platform</strong></h2>
    </div>

    <div class="pillar-tabs" id="pillarTabs">
      <button class="pillar-tab active" data-pillar="observe">
        <span class="pillar-num">01</span>
        <span class="pillar-name">Observe</span>
        <span class="pillar-desc">Live situational awareness</span>
      </button>
      <button class="pillar-tab" data-pillar="understand">
        <span class="pillar-num">02</span>
        <span class="pillar-name">Understand</span>
        <span class="pillar-desc">Data into insight</span>
      </button>
      <button class="pillar-tab" data-pillar="simulate">
        <span class="pillar-num">03</span>
        <span class="pillar-name">Simulate</span>
        <span class="pillar-desc">Model futures</span>
      </button>
      <button class="pillar-tab" data-pillar="collaborate">
        <span class="pillar-num">04</span>
        <span class="pillar-name">Collaborate</span>
        <span class="pillar-desc">Coordinate across borders</span>
      </button>
      <button class="pillar-tab" data-pillar="explore">
        <span class="pillar-num">05</span>
        <span class="pillar-name">Explore</span>
        <span class="pillar-desc">What-if scenarios</span>
      </button>
    </div>

    <div class="pillar-stage">
      <div class="pillar-feat-nav" id="pillarNav"></div>
      <div class="pillar-detail" id="pillarDetail"></div>
    </div>

    <div class="uc-actions">
      <a href={`${base}/contact`} class="btn-navy">Request Platform Access</a>
      <a href="https://airspace-hub.aero" class="btn-outline-navy" target="_blank">Open AIR Space Platform →</a>
    </div>
  </section>

  <!-- JOURNEY TIMELINE -->
  <section class="journey" id="journey">
    <div class="section-header" data-reveal>
      <div class="section-label">Platform Journey</div>
      <h2 class="section-title">Gradually unlocking new capabilities,<br><strong>year by year</strong></h2>
    </div>
    <div class="timeline">
      <div class="timeline-item" data-reveal data-reveal-delay="0">
        <div class="timeline-dot"></div>
        <div class="timeline-year">2019–23</div>
        <div class="timeline-heading">Initializing Capabilities</div>
        <div class="timeline-body">Foundational platform built on open technologies. Cloud-native architecture. Regional data pipelines established.</div>
      </div>
      <div class="timeline-item" data-reveal data-reveal-delay="100">
        <div class="timeline-dot"></div>
        <div class="timeline-year">2024</div>
        <div class="timeline-heading">Regional Awareness</div>
        <div class="timeline-body">Live &amp; historical data integration. 4D trajectory prediction. Real-time situational awareness for APAC airspace.</div>
      </div>
      <div class="timeline-item active" data-reveal data-reveal-delay="200">
        <div class="timeline-dot"></div>
        <div class="timeline-year">2025</div>
        <div class="timeline-heading">FF-ICE Onboarding</div>
        <div class="timeline-body">Progressive ANSP onboarding. Full FF-ICE/R1 stack deployed. Hybrid "what-if" analysis mode introduced.</div>
      </div>
      <div class="timeline-item" data-reveal data-reveal-delay="300">
        <div class="timeline-dot"></div>
        <div class="timeline-year" style="color:#fff;">2026</div>
        <div class="timeline-heading">Structured Collaboration</div>
        <div class="timeline-body">City-pair optimization. Advanced weather forecasting. High-impact use cases co-developed with ANSP partners.</div>
      </div>
    </div>
  </section>

  <!-- FACES OF AIR LAB -->
  <section class="faces" id="faces">
    <div class="faces-grid" data-reveal>
      <div class="faces-mosaic">
        <img class="fm-large" src={`${base}/face-1.jpg`} alt="AIR Lab team" />
        <img class="fm-top" src={`${base}/face-3.jpg`} alt="AIR Lab team" />
        <img class="fm-bot" src={`${base}/face-6.jpg`} alt="AIR Lab team" />
      </div>
      <div class="faces-text">
        <p class="faces-body">Engineers, developers, ATM specialists, ATCOs, and researchers from Thales and CAAS working side by side to advance aviation across the Asia-Pacific region.</p>
        <div class="faces-chips">
          <span class="face-chip">Engineering</span>
          <span class="face-chip">ATM Operations</span>
          <span class="face-chip">Research</span>
          <span class="face-chip">Data Science</span>
        </div>
        <div style="margin-top:8px;">
          <a href={`${base}/team`} class="btn-ghost">Meet the full team →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- NEWS PREVIEW -->
  <section class="news" id="news">
    <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:48px;" data-reveal>
      <div>
        <div class="section-label">Latest from AIR Lab</div>
        <h2 class="section-title" style="color:#fff;">News &amp;<br><strong>updates</strong></h2>
      </div>
      <a href={`${base}/news`} class="btn-ghost">All articles →</a>
    </div>
    <div class="news-grid">
      {latestNews.map((article: any, i: number) => (
        <div class="news-card" data-reveal data-reveal-delay={i * 100}>
          <div class="news-content">
            <span class="news-tag">{article.category}</span>
            {article.externalUrl ? (
              <a href={article.externalUrl} target="_blank" rel="noopener" class="news-title">{article.title}</a>
            ) : (
              <a href={`${base}/news/${article.slug.current}`} class="news-title">{article.title}</a>
            )}
            <p class="news-excerpt">{article.excerpt}</p>
            <span class="news-date">{article.publishedAt}</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- TEAM PREVIEW -->
  <section class="team" id="team">
    <div class="team-intro-grid">
      <img class="team-photo-large" src={`${base}/team-photo.jpg`} alt="AIR Lab team" data-reveal />
      <div class="team-intro-text" data-reveal data-reveal-delay="120">
        <div class="section-label">Our team</div>
        <h2 class="section-title">A team built on<br><strong>shared ambition.</strong></h2>
        <p class="section-intro">Engineers, ATM specialists, researchers, and operators from Thales and CAAS, working side by side to advance aviation in the Asia-Pacific region.</p>
        <div style="display:flex;gap:16px;flex-wrap:wrap;">
          <a href={`${base}/team`} class="btn-white">Meet the full team</a>
          <a href={`${base}/contact`} class="btn-outline-white">Contact AIR Lab</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PARTNERS STRIP -->
  <section class="partners" id="partners">
    <div class="section-header" style="margin-bottom:40px;" data-reveal>
      <div class="section-label">Our Partners</div>
      <h2 class="section-title">Trusted by<br><strong>aviation leaders</strong></h2>
    </div>
    <div class="partners-grid">
      <div class="partner-cell">
        <a href="https://www.caas.gov.sg" target="_blank" rel="noopener" class="partner-logo-link">
          <img src={`${base}/images/partners/caas.png`} alt="CAAS" class="partner-logo" />
        </a>
      </div>
      <div class="partner-cell">
        <a href="https://www.thalesgroup.com" target="_blank" rel="noopener" class="partner-logo-link">
          <img src={`${base}/images/partners/thales.webp`} alt="Thales" class="partner-logo" />
        </a>
      </div>
      <div class="partner-cell">
        <img src={`${base}/images/partners/sginnovate.png`} alt="SGInnovate" class="partner-logo" />
      </div>
      <div class="partner-cell">
        <img src={`${base}/images/partners/meteomatics.png`} alt="Meteomatics" class="partner-logo" />
      </div>
      <div class="partner-cell">
        <img src={`${base}/images/partners/tomorrow.png`} alt="Tomorrow.io" class="partner-logo" />
      </div>
    </div>
    <div style="margin-top:32px;">
      <a href={`${base}/partners`} class="btn-outline-navy">View all partners →</a>
    </div>
  </section>

  <!-- CONTACT CTA -->
  <div class="contact-cta" id="contact">
    <div class="contact-cta-text" data-reveal>
      <div class="section-label">Get involved</div>
      <h2 class="section-title" set:html={ctaTitle.replace(/(collaboration\??)/i, '<br><strong>$1</strong>')}></h2>
      <p class="section-intro">{ctaSubtitle}</p>
      <div class="contact-cta-actions">
        <a href={`${base}/contact`} class="btn-white">Contact AIR Lab</a>
        <a href={`${base}/join-us`} class="btn-outline-white">Join the team →</a>
      </div>
    </div>
    <div class="contact-detail" data-reveal data-reveal-delay="150">
      <div class="contact-item">
        <span class="contact-item-label">Location</span>
        <span class="contact-item-value" set:html={ctaLocation.replace(/\n/g, '<br>')}></span>
      </div>
      <div class="contact-item">
        <span class="contact-item-label">Platform access</span>
        <span class="contact-item-value">
          <a href={ctaPlatformUrl} target="_blank">Log in to the RCP →</a>
        </span>
      </div>
    </div>
  </div>

  <Footer slot="footer" />
</Base>

<script>
  const video = document.getElementById('hero-video') as HTMLVideoElement;
  if (video) {
    video.playbackRate = 0.5;
    video.addEventListener('loadedmetadata', () => { video.currentTime = 180; });
    video.addEventListener('timeupdate', () => { if (video.currentTime >= 215) video.currentTime = 180; });
    video.play().catch(() => {});
  }

  // ── Platform pillars ──
  const RCP_BASE = import.meta.env.BASE_URL.replace(/\/$/, '') + '/rcp';

  const PILLARS: Record<string, { features: { id: string; title: string; desc: string; tag: string; src: string; type: 'img' | 'video' }[] }> = {
    observe: { features: [
      { id: 'lasd', title: 'Live Air Situation Display', desc: 'Global surveillance air-situation picture from different sources (track fusion), providing a comprehensive and increasingly stable view of regional air traffic.', tag: 'Real-time', src: RCP_BASE+'/observe-asd.png', type: 'img' },
      { id: 'hybrid', title: 'Hybrid Mode & Replay', desc: 'Blend live and historical data with simulated traffic. Replay any past traffic scenario for analysis or training.', tag: 'Analysis', src: RCP_BASE+'/observe-hybrid.png', type: 'img' },
      { id: 'fpg', title: 'Flight Plan & Trajectory Generator', desc: 'AI-driven generator creating optimised 4D trajectories using ML models to balance efficiency, operational constraints, and dynamic factors such as weather.', tag: 'AI', src: RCP_BASE+'/observe-fpg.mp4', type: 'video' },
      { id: 'sigmet', title: 'SIGMET', desc: 'Weather-related information, including SIGMET-based constraints, integrated into the RCP environment to improve shared situational awareness and support weather-aware traffic assessment.', tag: 'Weather', src: RCP_BASE+'/observe-sigmet.mp4', type: 'video' },
    ]},
    understand: { features: [
      { id: 'hotspot', title: 'Hotspots & Demand Forecasting', desc: 'Predict saturation points and capacity bottlenecks under different traffic growth scenarios across the SEA region.', tag: 'Forecasting', src: RCP_BASE+'/understand-hotspots.mp4', type: 'video' },
      { id: 'kpi', title: 'KPIs & Regional Indicators', desc: 'Capacity, punctuality, and efficiency across your region at a glance, with dashboards built for ANSP operational needs.', tag: 'Analytics', src: RCP_BASE+'/understand-kpi.png', type: 'img' },
      { id: 'rh', title: 'Regional Health', desc: 'A monthly snapshot of South East Asian airspace: routes, airports, flight levels, and peak traffic trends.', tag: 'Monthly', src: RCP_BASE+'/understand-regional-health.png', type: 'img' },
    ]},
    simulate: { features: [
      { id: 'scenario', title: 'Scenario Editor', desc: 'Build any traffic or airspace scenario in minutes: modify traffic density, routes, sector boundaries, and weather constraints.', tag: 'Editor', src: RCP_BASE+'/simulate-scenario.mp4', type: 'video' },
      { id: 'fts', title: 'Fast-time Simulation', desc: 'Run a full day of traffic in seconds. Compare outcomes side by side across multiple scenarios to validate ATM concepts.', tag: 'Research', src: RCP_BASE+'/simulate-fts.mp4', type: 'video' },
      { id: 'cdr', title: 'Area Avoidance & CDR', desc: 'Define exclusion zones and watch the network automatically re-route around them, with conflict detection and resolution built in.', tag: 'Safety', src: RCP_BASE+'/simulate-cdr.mp4', type: 'video' },
    ]},
    collaborate: { features: [
      { id: 'ffice', title: 'FF-ICE Trajectory Negotiation', desc: 'eAU and eASP services. FF-ICE/R1 flight plans integrated into the RCP; agreed trajectories available for collaborative awareness and trajectory forecast between ANSPs and airlines.', tag: 'ICAO Standard', src: RCP_BASE+'/collaborate-ffice.mp4', type: 'video' },
    ]},
    explore: { features: [
      { id: 'whatif', title: 'What-if Explorer', desc: 'Toggle constraints on and off: runway closures, sector redesigns, demand surges, and instantly see the downstream impact on the regional network.', tag: 'Simulation', src: RCP_BASE+'/explore-whatif.mp4', type: 'video' },
    ]},
  };

  let currentPillar = 'observe';
  let currentIdx = 0;

  function renderPillar(pillar: string, idx: number) {
    currentIdx = idx;
    const feats = PILLARS[pillar].features;
    const f = feats[idx];

    // Detail: text flush against image, no gap
    const detail = document.getElementById('pillarDetail')!;
    const media = f.type === 'video'
      ? `<video src="${f.src}" autoplay muted loop playsinline></video>`
      : `<img src="${f.src}" alt="${f.title}">`;
    detail.innerHTML = `
      <div class="pl-info">
        <span class="pl-tag">${f.tag}</span>
        <div class="pl-title">${f.title}</div>
        <p class="pl-desc">${f.desc}</p>
      </div>
      <div class="pillar-visual">${media}</div>`;

    // Feature nav
    const nav = document.getElementById('pillarNav')!;
    nav.innerHTML = feats.map((ft, i) => `
      <button class="pfn-btn ${i === idx ? 'active' : ''}" data-fi="${i}">
        <span class="pfn-dot"></span>
        <span class="pfn-name">${ft.title}</span>
      </button>`).join('');
    nav.querySelectorAll<HTMLButtonElement>('.pfn-btn').forEach(btn => {
      btn.addEventListener('click', () => renderPillar(pillar, Number(btn.dataset.fi)));
    });
  }

  document.querySelectorAll<HTMLButtonElement>('.pillar-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.pillar-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      currentPillar = tab.dataset.pillar!;
      renderPillar(currentPillar, 0);
    });
  });

  renderPillar('observe', 0);
</script>
