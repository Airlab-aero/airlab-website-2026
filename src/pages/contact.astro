---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { client, contactPageQuery } from '../lib/sanity';

const cms = await client.fetch(contactPageQuery) ?? {};
const heroSubtitle = cms.heroSubtitle ?? "Whether you're interested in partnership, research collaboration, or learning more about the RCP platform, we'd love to hear from you.";
const address = cms.address ?? 'AIR Lab @ WeWork\nSuntec Tower 5\nTemasek Boulevard\nSingapore 038985';
const apiUrl = cms.apiUrl ?? 'https://open-atms.airlab.aero/public-api/';
const rcpUrl = cms.rcpUrl ?? 'https://rcp-landing-page.rcp.pub.airlab.thalesdigital.io/';
---

<Base title="Contact" description="Get in touch with AIR Lab Singapore — based at WeWork Suntec Tower 5.">
  <Nav slot="nav" />

  <div class="page-hero">
    <div class="page-hero-content">
      <div class="section-label">Get in touch</div>
      <h1>Contact<br><strong>AIR Lab</strong></h1>
      <p>{heroSubtitle}</p>
    </div>
  </div>

  <section style="background: var(--off-white);">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start;">
      <div>
        <div class="section-label">Location</div>
        <h2 class="section-title" style="margin-bottom: 32px;">Visit <strong>us</strong></h2>
        <div class="contact-detail">
          <div class="contact-item">
            <span class="contact-item-label">Address</span>
            <span class="contact-item-value" set:html={address.replace(/\n/g, '<br>')}></span>
          </div>
          <div class="contact-item">
            <span class="contact-item-label">RCP Platform</span>
            <span class="contact-item-value">
              <a href={rcpUrl} target="_blank">Log In to the RCP →</a>
            </span>
          </div>
        </div>
      </div>
      <div>
        <div class="section-label">Enquiries</div>
        <h2 class="section-title" style="margin-bottom: 32px;">Send us a <strong>message</strong></h2>
        <form
          id="contactForm"
          style="display: flex; flex-direction: column; gap: 20px;"
        >
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div style="display: flex; flex-direction: column; gap: 8px;">
              <label style="font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); font-weight: 500;">Name</label>
              <input type="text" name="name" required style="padding: 12px 16px; border: 1px solid var(--border); border-radius: 4px; font-family: var(--font); font-size: 15px; color: var(--text); background: #fff; outline: none;" />
            </div>
            <div style="display: flex; flex-direction: column; gap: 8px;">
              <label style="font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); font-weight: 500;">Email</label>
              <input type="email" name="email" required style="padding: 12px 16px; border: 1px solid var(--border); border-radius: 4px; font-family: var(--font); font-size: 15px; color: var(--text); background: #fff; outline: none;" />
            </div>
          </div>
          <div style="display: flex; flex-direction: column; gap: 8px;">
            <label style="font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); font-weight: 500;">Organisation</label>
            <input type="text" name="organisation" style="padding: 12px 16px; border: 1px solid var(--border); border-radius: 4px; font-family: var(--font); font-size: 15px; color: var(--text); background: #fff; outline: none;" />
          </div>
          <div style="display: flex; flex-direction: column; gap: 8px;">
            <label style="font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); font-weight: 500;">Message</label>
            <textarea name="message" rows="5" required style="padding: 12px 16px; border: 1px solid var(--border); border-radius: 4px; font-family: var(--font); font-size: 15px; color: var(--text); background: #fff; outline: none; resize: vertical;"></textarea>
          </div>
          <div id="formStatus" style="display:none; font-size:14px; padding: 12px 16px; border-radius: 4px;"></div>
          <button type="submit" id="formSubmit" class="btn-airlab" style="align-self: flex-start; border: none; cursor: pointer;">Send message →</button>
        </form>

        <script>
          const form = document.getElementById('contactForm') as HTMLFormElement;
          const status = document.getElementById('formStatus')!;
          const btn = document.getElementById('formSubmit') as HTMLButtonElement;

          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            btn.disabled = true;
            btn.textContent = 'Sending…';

            const data = new FormData(form);

            try {
              const res = await fetch('https://formspree.io/f/contact@airlab.aero', {
                method: 'POST',
                body: data,
                headers: { Accept: 'application/json' },
              });

              if (res.ok) {
                status.style.display = 'block';
                status.style.background = '#e6f9f0';
                status.style.color = '#0a6640';
                status.textContent = '✓ Message sent — we'll get back to you shortly.';
                form.reset();
                btn.style.display = 'none';
              } else {
                throw new Error('error');
              }
            } catch {
              status.style.display = 'block';
              status.style.background = '#fff3f3';
              status.style.color = '#c0392b';
              status.textContent = 'Something went wrong. Please email us directly at contact@airlab.aero';
              btn.disabled = false;
              btn.textContent = 'Send message →';
            }
          });
        </script>
      </div>
    </div>
  </section>

  <div class="contact-map">
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3988.801!2d103.8555!3d1.2937!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31da199b4e47551d%3A0xd2de2cf33e498f60!2sSuntec%20Tower%20Five!5e0!3m2!1sen!2ssg!4v1"
      title="AIR Lab — WeWork Suntec Tower 5, Singapore"
      allowfullscreen
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
    <a class="map-link" href="https://maps.google.com/?q=Suntec+Tower+5+Singapore" target="_blank" rel="noopener">Open in Google Maps →</a>
  </div>

  <Footer slot="footer" />
</Base>

<style>
  /* override global contact-item colors (designed for dark teal bg) */
  section .contact-item-label { color: var(--muted); }
  section .contact-item-value { color: var(--navy); }
  section .contact-item-value a { color: var(--teal); }
  section .contact-item-value a:hover { color: var(--navy); }
  section .contact-item { border-bottom: 1px solid var(--border); padding-bottom: 20px; }

  .contact-map { position: relative; height: 440px; background: #e8eaf0; }
  .contact-map iframe { width: 100%; height: 100%; border: 0; display: block; }
  .map-link { position: absolute; bottom: 16px; right: 16px; background: var(--navy); color: #fff; font-size: 12px; padding: 6px 14px; border-radius: 4px; text-decoration: none; font-family: var(--font); transition: background 0.2s; }
  .map-link:hover { background: var(--teal); }
</style>
