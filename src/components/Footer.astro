---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer>
  <div class="footer-brand">
    <div class="footer-logo">
      <img src={`${base}/airlab-logo.png`} alt="AIR Lab" />
    </div>
    <p>Advancing global aviation efficiency and sustainability through innovative ATM solutions, open technologies, and regional collaboration.</p>
  </div>
  <div class="footer-col">
    <h4>Platform</h4>
    <a href={`${base}/#platform`}>About the RCP</a>
    <a href={`${base}/#use-cases`}>Use Cases</a>
    <a href="https://rcp-landing-page.rcp.pub.airlab.thalesdigital.io/" target="_blank">Log In to RCP</a>
  </div>
  <div class="footer-col">
    <h4>Organisation</h4>
    <a href={`${base}/team`}>Team</a>
    <a href={`${base}/partners`}>Partners</a>
    <a href={`${base}/join-us`}>Join Us</a>
    <a href={`${base}/contact`}>Contact</a>
  </div>
  <div class="footer-col">
    <h4>Resources</h4>
    <a href={`${base}/news`}>News</a>
    <a href={`${base}/contact`}>Contact</a>
    <a href={`${base}/terms`}>Terms of Use</a>
    <a href={`${base}/privacy`}>Privacy Policy</a>
  </div>
</footer>
<div class="footer-bottom">
  <p>&copy; {year} AIR Lab. All rights reserved.</p>
  <div>
    <a href={`${base}/terms`}>Terms of Use</a>
    <a href={`${base}/privacy`}>Privacy Policy</a>
  </div>
</div>
